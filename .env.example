# Safe environment template for local development and AI Studio deployment.
# Do not commit real secrets. Fill these values in your deployment environment.

# Server Configuration
NODE_ENV=development
PORT=3000
SITE_URL=https://your-domain.example

# Database (MongoDB - Optional)
MONGODB_URI=

# Session Secret (set a strong random value in your actual environment)
SESSION_SECRET=

# Email Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Email Addresses
EMAIL_INFO=info@your-domain.example
EMAIL_SUPPORT=support@your-domain.example
EMAIL_HELLO=hello@your-domain.example

# AI Chatbot
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Companies House API
COMPANIES_HOUSE_API_KEY=

# Admin Configuration
ADMIN_EMAIL=admin@your-domain.example
SITE_NAME=UK Ltd Registration

# External Services (Optional)
GOOGLE_ANALYTICS_ID=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

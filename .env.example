# Server Configuration
NODE_ENV=development
PORT=3000
SITE_URL=http://localhost:3000

# Database (MongoDB - Optional)
MONGODB_URI=

# Session Secret (GENERATE: openssl rand -hex 32)
SESSION_SECRET=change-this-to-random-32-character-string-in-production

# Email Configuration (Hostinger SMTP)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@ukltdregistration.com
SMTP_PASS=

# Email Addresses
EMAIL_INFO=info@ukltdregistration.com
EMAIL_SUPPORT=support@ukltdregistration.com
EMAIL_HELLO=hello@ukltdregistration.com

# Paddle Payment Gateway
PADDLE_VENDOR_ID=
PADDLE_API_KEY=
PADDLE_PUBLIC_KEY=
PADDLE_ENVIRONMENT=sandbox

# AI Chatbot
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Companies House API
COMPANIES_HOUSE_API_KEY=

# Admin Configuration
ADMIN_EMAIL=admin@ukltdregistration.com
SITE_NAME=UK Ltd Registration

# External Services (Optional)
GOOGLE_ANALYTICS_ID=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Rate Limiting (Override defaults)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

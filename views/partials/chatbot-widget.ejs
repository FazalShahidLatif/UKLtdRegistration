<!-- AI Assistant Widget (Olivia) -->
<div id="ai-chat-widget" class="fixed bottom-6 right-6 z-[9999]">
    <!-- Toggle Button -->
    <button onclick="toggleChat()" id="chat-toggle-btn"
        class="w-14 h-14 bg-brand-blue rounded-2xl flex items-center justify-center text-white shadow-2xl shadow-blue-300/50 hover:bg-brand-navy transition-all duration-300 relative">
        <svg id="chat-icon" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
        <svg id="close-icon" class="w-7 h-7 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        <span class="absolute -top-1 -right-1 w-3.5 h-3.5 bg-brand-green border-2 border-white rounded-full"></span>
    </button>

    <!-- Chat Window — fixed, viewport-safe, no overflow -->
    <div id="chat-window"
        class="hidden fixed bottom-24 right-6 w-[360px] max-w-[calc(100vw-3rem)] bg-white rounded-[1.75rem] shadow-2xl shadow-gray-900/15 border border-gray-100 flex flex-col overflow-hidden opacity-0 scale-95 translate-y-3 transition-all duration-300 origin-bottom-right"
        style="max-height: min(560px, 85vh);">

        <!-- Header: solid brand-navy, no clashing gradient -->
        <div class="bg-brand-navy px-5 py-4 flex items-center justify-between flex-shrink-0">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 bg-brand-blue rounded-xl flex items-center justify-center text-white text-[11px] font-black">OS</div>
                <div>
                    <p class="text-white font-black text-sm leading-tight">Olivia</p>
                    <div class="flex items-center gap-1.5 mt-0.5">
                        <span class="w-1.5 h-1.5 bg-brand-green rounded-full animate-pulse"></span>
                        <span class="text-[10px] font-bold text-blue-200 uppercase tracking-widest">Formation Specialist</span>
                    </div>
                </div>
            </div>
            <button onclick="toggleChat()" class="text-white/50 hover:text-white transition p-1 rounded-lg hover:bg-white/10">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <!-- Tagline bar -->
        <div class="bg-brand-blue/5 border-b border-gray-100 px-5 py-2 flex-shrink-0">
            <p class="text-[10px] text-gray-400 font-medium">Expert advice on UK company formation, SIC codes & banking.</p>
        </div>

        <!-- Messages Area -->
        <div id="chat-messages" class="flex-1 overflow-y-auto p-5 space-y-4 bg-gray-50/40 overscroll-contain">
            <div class="flex items-start">
                <div class="bg-white border border-gray-100 px-4 py-3 rounded-2xl rounded-tl-md shadow-sm text-sm text-gray-700 max-w-[88%] leading-relaxed">
                    <% if (locals.user) { %>
                        Hello <strong><%= user.email.split('@')[0] %></strong>! I'm Olivia, your UK Ltd formation expert. How can I help you today?
                    <% } else { %>
                        Hello! I'm Olivia, your UK Ltd formation expert. How can I help you build your business today?
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Typing Indicator -->
        <div id="typing-indicator" class="px-5 py-2 hidden flex-shrink-0">
            <div class="flex items-center gap-1">
                <div class="w-2 h-2 bg-brand-blue/40 rounded-full animate-bounce"></div>
                <div class="w-2 h-2 bg-brand-blue/40 rounded-full animate-bounce [animation-delay:-.3s]"></div>
                <div class="w-2 h-2 bg-brand-blue/40 rounded-full animate-bounce [animation-delay:-.5s]"></div>
            </div>
        </div>

        <!-- Input Area -->
        <div class="p-4 bg-white border-t border-gray-100 flex-shrink-0">
            <div class="relative flex items-center">
                <input type="text" id="chat-input" onkeypress="handleKey(event)"
                    placeholder="Ask me anything..."
                    class="w-full pl-4 pr-12 py-3 bg-gray-50 border border-gray-100 rounded-2xl text-sm text-gray-900 outline-none focus:ring-2 focus:ring-brand-blue/30 focus:bg-white transition-all placeholder-gray-400">
                <button onclick="sendMessage()"
                    class="absolute right-2 w-8 h-8 bg-brand-blue text-white rounded-xl flex items-center justify-center hover:bg-brand-navy transition active:scale-90 shadow-md shadow-blue-100">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let chatHistory = [];
    const chatWindow = document.getElementById('chat-window');
    const messagesArea = document.getElementById('chat-messages');
    const chatInput = document.getElementById('chat-input');
    const chatIcon = document.getElementById('chat-icon');
    const closeIcon = document.getElementById('close-icon');
    const typingIndicator = document.getElementById('typing-indicator');

    function toggleChat() {
        const isHidden = chatWindow.classList.contains('hidden');
        if (isHidden) {
            chatWindow.classList.remove('hidden');
            setTimeout(() => {
                chatWindow.classList.remove('opacity-0', 'translate-y-3', 'scale-95');
                chatWindow.classList.add('opacity-100', 'translate-y-0', 'scale-100');
            }, 10);
            chatIcon.classList.add('hidden');
            closeIcon.classList.remove('hidden');
        } else {
            chatWindow.classList.add('opacity-0', 'translate-y-3', 'scale-95');
            chatWindow.classList.remove('opacity-100', 'translate-y-0', 'scale-100');
            setTimeout(() => {
                chatWindow.classList.add('hidden');
            }, 300);
            chatIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
        }
    }

    function handleKey(e) {
        if (e.key === 'Enter') sendMessage();
    }

    async function sendMessage() {
        const text = chatInput.value.trim();
        if (!text) return;

        appendMessage('user', text);
        chatInput.value = '';
        chatHistory.push({ role: 'user', content: text });

        typingIndicator.classList.remove('hidden');
        messagesArea.scrollTop = messagesArea.scrollHeight;

        try {
            const response = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ messages: chatHistory })
            });
            const data = await response.json();
            typingIndicator.classList.add('hidden');
            if (data.content) {
                appendMessage('assistant', data.content);
                chatHistory.push({ role: 'assistant', content: data.content });
            }
        } catch (error) {
            typingIndicator.classList.add('hidden');
            appendMessage('assistant', "Sorry, I'm having trouble connecting. Please try again.");
        }
    }

    function appendMessage(role, text) {
        const div = document.createElement('div');
        div.className = `flex items-start ${role === 'user' ? 'justify-end' : ''}`;
        const inner = document.createElement('div');
        if (role === 'assistant') {
            inner.className = "bg-white border border-gray-100 px-4 py-3 rounded-2xl rounded-tl-md shadow-sm text-sm text-gray-700 max-w-[88%] leading-relaxed";
        } else {
            inner.className = "bg-brand-blue text-white px-4 py-3 rounded-2xl rounded-tr-md shadow-lg shadow-blue-100 text-sm max-w-[88%] leading-relaxed";
        }
        inner.innerText = text;
        div.appendChild(inner);
        messagesArea.appendChild(div);
        messagesArea.scrollTop = messagesArea.scrollHeight;
    }
</script>

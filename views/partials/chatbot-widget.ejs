<!-- AI Assistant Widget -->
<div id="ai-chat-widget" class="fixed bottom-8 right-8 z-[9999] group">
    <!-- Chat Toggle Button -->
    <button onclick="toggleChat()" class="w-16 h-16 bg-blue-600 rounded-2xl flex items-center justify-center text-white shadow-2xl shadow-blue-200 hover:bg-blue-700 hover:scale-110 transition-all duration-300 relative">
        <svg id="chat-icon" class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
        <svg id="close-icon" class="w-8 h-8 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        <span class="absolute -top-1 -right-1 w-4 h-4 bg-green-500 border-2 border-white rounded-full"></span>
    </button>

    <!-- Chat Window -->
    <div id="chat-window" class="absolute bottom-20 right-0 w-[350px] md:w-[400px] h-[550px] bg-white rounded-3xl shadow-2xl border border-gray-100 flex flex-col overflow-hidden hidden transform transition-all duration-300 translate-y-4 opacity-0 scale-95">
        <!-- Header -->
        <div class="bg-gradient-to-br from-blue-600 to-indigo-700 p-6 text-white">
            <div class="flex items-center justify-between mb-2">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 bg-white/20 backdrop-blur-md rounded-xl flex items-center justify-center font-black">OL</div>
                    <div>
                        <h4 class="font-bold">Olivia</h4>
                        <div class="flex items-center text-[10px] text-blue-100">
                            <span class="w-2 h-2 bg-green-400 rounded-full mr-2 animate-pulse"></span>
                            Formation Specialist
                        </div>
                    </div>
                </div>
                <button onclick="toggleChat()" class="text-white/70 hover:text-white"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
            </div>
            <p class="text-xs text-blue-50/80">Expert advice on UK company formation, SIC codes, and banking.</p>
        </div>

        <!-- Messages Area -->
        <div id="chat-messages" class="flex-1 overflow-y-auto p-6 space-y-4 bg-gray-50/50 custom-scrollbar">
            <div class="flex items-start">
                <div class="bg-white border border-gray-100 p-4 rounded-2xl rounded-tl-none shadow-sm text-sm text-gray-700 max-w-[85%]">
                    <% if (locals.user) { %>
                        Hello <%= user.email.split('@')[0] %>! I'm Olivia, your UK Ltd formation expert. How can I help you build your business today?
                    <% } else { %>
                        Hello! I'm Olivia, your UK Ltd formation expert. How can I help you build your business today?
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Typing Indicator -->
        <div id="typing-indicator" class="px-6 py-2 hidden">
            <div class="flex space-x-1">
                <div class="w-1.5 h-1.5 bg-blue-600 rounded-full animate-bounce"></div>
                <div class="w-1.5 h-1.5 bg-blue-600 rounded-full animate-bounce [animation-delay:-.3s]"></div>
                <div class="w-1.5 h-1.5 bg-blue-600 rounded-full animate-bounce [animation-delay:-.5s]"></div>
            </div>
        </div>

        <!-- Input Area -->
        <div class="p-4 bg-white border-t border-gray-100">
            <div class="relative">
                <input type="text" id="chat-input" onkeypress="handleKey(event)" placeholder="Ask me anything..." 
                    class="w-full pl-5 pr-12 py-4 bg-gray-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-600 focus:bg-white transition-all outline-none text-sm">
                <button onclick="sendMessage()" class="absolute right-2 top-2 bottom-2 bg-blue-600 text-white w-10 h-10 rounded-xl flex items-center justify-center shadow-lg shadow-blue-100 hover:bg-blue-700 transition active:scale-95">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let chatHistory = [];
    const chatWindow = document.getElementById('chat-window');
    const messagesArea = document.getElementById('chat-messages');
    const chatInput = document.getElementById('chat-input');
    const chatIcon = document.getElementById('chat-icon');
    const closeIcon = document.getElementById('close-icon');
    const typingIndicator = document.getElementById('typing-indicator');

    function toggleChat() {
        const isHidden = chatWindow.classList.contains('hidden');
        if (isHidden) {
            chatWindow.classList.remove('hidden');
            setTimeout(() => {
                chatWindow.classList.remove('opacity-0', 'translate-y-4', 'scale-95');
                chatWindow.classList.add('opacity-100', 'translate-y-0', 'scale-100');
            }, 10);
            chatIcon.classList.add('hidden');
            closeIcon.classList.remove('hidden');
        } else {
            chatWindow.classList.add('opacity-0', 'translate-y-4', 'scale-95');
            chatWindow.classList.remove('opacity-100', 'translate-y-0', 'scale-100');
            setTimeout(() => {
                chatWindow.classList.add('hidden');
            }, 300);
            chatIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
        }
    }

    function handleKey(e) {
        if (e.key === 'Enter') sendMessage();
    }

    async function sendMessage() {
        const text = chatInput.value.trim();
        if (!text) return;

        // Add user message
        appendMessage('user', text);
        chatInput.value = '';
        chatHistory.push({ role: 'user', content: text });

        // Show typing
        typingIndicator.classList.remove('hidden');
        messagesArea.scrollTop = messagesArea.scrollHeight;

        try {
            const response = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ messages: chatHistory })
            });
            const data = await response.json();
            
            // Hide typing
            typingIndicator.classList.add('hidden');

            if (data.content) {
                appendMessage('assistant', data.content);
                chatHistory.push({ role: 'assistant', content: data.content });
            }
        } catch (error) {
            typingIndicator.classList.add('hidden');
            appendMessage('assistant', "Sorry, I'm having trouble connecting to my brain. Please try again later.");
        }
    }

    function appendMessage(role, text) {
        const div = document.createElement('div');
        div.className = `flex items-start ${role === 'user' ? 'justify-end' : ''}`;
        
        const inner = document.createElement('div');
        if (role === 'assistant') {
            inner.className = "bg-white border border-gray-100 p-4 rounded-2xl rounded-tl-none shadow-sm text-sm text-gray-700 max-w-[85%] leading-relaxed";
        } else {
            inner.className = "bg-blue-600 text-white p-4 rounded-2xl rounded-tr-none shadow-xl shadow-blue-100 text-sm max-w-[85%] leading-relaxed";
        }
        inner.innerText = text;
        
        div.appendChild(inner);
        messagesArea.appendChild(div);
        messagesArea.scrollTop = messagesArea.scrollHeight;
    }
</script>

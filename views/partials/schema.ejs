<!-- JSON-LD Schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "<%= siteUrl %>/#organization",
      "name": "<%= siteName %>",
      "url": "<%= siteUrl %>",
      "logo": {
        "@type": "ImageObject",
        "url": "<%= siteUrl %>/images/favicon.png",
        "width": 192,
        "height": 192
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "312",
        "bestRating": "5",
        "worstRating": "1"
      },
      "contactPoint": [
        {
          "@type": "ContactPoint",
          "telephone": "+92-332-213-7898",
          "contactType": "customer support",
          "areaServed": "PK",
          "availableLanguage": ["English", "Urdu"]
        }
      ],
      "sameAs": [
        "https://twitter.com/ukltdreg",
        "https://facebook.com/ukltdreg",
        "https://linkedin.com/company/ukltdreg"
      ]
    },
    {
      "@type": "LocalBusiness",
      "@id": "<%= siteUrl %>/#localbusiness",
      "name": "<%= siteName %> Pakistan",
      "image": "<%= siteUrl %>/images/og-image.jpg",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "26/792 Cantt Bazar Drigh Road",
        "addressLocality": "Karachi",
        "postalCode": "75350",
        "addressCountry": "PK"
      },
      "telephone": "WhatsApp +92 332 213 7898",
      "url": "<%= siteUrl %>",
      "priceRange": "$$"
    },
    {
      "@type": "WebSite",
      "@id": "<%= siteUrl %>/#website",
      "url": "<%= siteUrl %>",
      "name": "<%= siteName %>",
      "publisher": {
        "@id": "<%= siteUrl %>/#organization"
      },
      "potentialAction": {
        "@type": "SearchAction",
        "target": "<%= siteUrl %>/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "WebPage",
      "@id": "<%= siteUrl %><%= currentPath %>#webpage",
      "url": "<%= siteUrl %><%= currentPath %>",
      "name": "<%= title %> | <%= siteName %>",
      "description": "<%= metaDescription %>",
      "isPartOf": {
        "@id": "<%= siteUrl %>/#website"
      },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "<%= siteUrl %>"
          }
          <% if (currentPath !== '/') { %>
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": "<%= title %>",
            "item": "<%= siteUrl %><%= currentPath %>"
          }
          <% } %>
        ]
      }
    }
    <% if (typeof article !== 'undefined' && article) { %>
    ,{
      "@type": "BlogPosting",
      "headline": "<%= article.title %>",
      "description": "<%= article.metaDescription || article.excerpt %>",
      "image": "<%= siteUrl %><%= article.image %>",
      "author": {
        "@type": "Organization",
        "name": "<%= siteName %>"
      },
      "publisher": {
        "@id": "<%= siteUrl %>/#organization"
      },
      "datePublished": "<%= article.publishedDate || '2026-04-27' %>",
      "dateModified": "<%= article.updatedDate || article.publishedDate || '2026-04-27' %>",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "<%= siteUrl %><%= currentPath %>"
      }
    }
    <% } %>
    <% if (currentPath === '/faq') { %>
    ,{
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Can a non-resident register a UK company?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, anyone of any nationality can register a UK Limited Company, provided they have a UK registered office address."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need to visit the UK to open a business bank account?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No, digital banks like Wise, Revolut, and Tide allow remote account opening for non-residents."
          }
        }
      ]
    }
    <% } %>
    <% if (currentPath === '/uk-ltd-formation-for-non-residents') { %>
    ,{
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How to open a company in the UK as a non-resident?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Non-residents can open a UK company by using an authorized formation agent. You will need to provide basic company details, appoint directors and shareholders (no UK residency required), and have a UK registered office address."
          }
        },
        {
          "@type": "Question",
          "name": "What are the legal requirements for a UK non-resident company?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Legal requirements include a unique company name, at least one director, at least one shareholder, a UK registered office address, and declaring any person with significant control (PSC) to Companies House."
          }
        },
        {
          "@type": "Question",
          "name": "Can I open a UK business bank account from abroad?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, while traditional high street banks may have stricter requirements, many UK based digital banking platforms specialized for businesses allow non-residents to open accounts remotely."
          }
        }
      ]
    }
    <% } %>
    <% if (currentPath === '/get-help-forming-a-uk-ltd') { %>
    ,{
      "@type": "Service",
      "name": "UK LTD Registration Formation",
      "provider": {
        "@id": "<%= siteUrl %>/#organization"
      },
      "areaServed": "Worldwide",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "128",
        "bestRating": "5",
        "worstRating": "1"
      },
      "offers": {
        "@type": "Offer",
        "price": "119.99",
        "priceCurrency": "GBP",
        "availability": "https://schema.org/InStock"
      }
    }
    <% } %>
    <% if (currentPath === '/services/virtual-office') { %>
    ,{

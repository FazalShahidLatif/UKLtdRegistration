    <% } %>
    <% if (currentPath === '/faq') { %>
    ,{
      "@type": "FAQPage",
      "mainEntity": [
        {"@type":"Question","name":"What is ltd company UK registration and how does it work?","acceptedAnswer":{"@type":"Answer","text":"Ltd company UK registration is the official process of incorporating a private limited company at Companies House. You submit a Memorandum of Association, Articles of Association, and an IN01 form. Companies House issues a Certificate of Incorporation confirming your company number and registered name. The entire process is done electronically. Our ACSP-verified agents transmit directly to the government gateway, achieving same-day approval in most cases."}},
        {"@type":"Question","name":"How long does a new ltd company registration take?","acceptedAnswer":{"@type":"Answer","text":"A new ltd company registration submitted via our same-day service before 3 PM UK time is typically approved by Companies House within 3-6 working hours. Standard registrations are processed within 24-48 working hours. We submit electronically directly to the government gateway with no postal delays."}},
        {"@type":"Question","name":"Can non-residents complete a new ltd company registration in the UK?","acceptedAnswer":{"@type":"Answer","text":"Yes. There is no requirement to be a UK resident to complete a new ltd company registration. We specialise in helping international founders form companies from anywhere in the world. You need a UK registered office address (which we provide) and valid ID for all directors."}},
        {"@type":"Question","name":"How do I check company name availability UK?","acceptedAnswer":{"@type":"Answer","text":"Use our free company names search tool at /company-name-check to check company name availability UK instantly. It queries the live Companies House register (over 5 million companies) applying the same too-like matching rules used by Companies House internally."}},
        {"@type":"Question","name":"What are the rules for ltd company names?","acceptedAnswer":{"@type":"Answer","text":"Ltd company names must: end in Limited or Ltd (or Welsh equivalents), not be identical or too similar to an existing registered name, not contain sensitive words (Bank, Royal, Chartered) without approval, not imply a government connection, and not be offensive or illegal."}},
        {"@type":"Question","name":"What is the ltd company names register?","acceptedAnswer":{"@type":"Answer","text":"The ltd company names register is the official Companies House index of all incorporated UK companies - both active and dissolved - containing over 5 million entries. When you apply for a new ltd company registration, Companies House checks your name against this register using its same-as algorithm."}},
        {"@type":"Question","name":"Can I reserve a company name before registration?","acceptedAnswer":{"@type":"Answer","text":"No. Companies House does not allow name reservations. The only way to secure a ltd company name is to actively incorporate it. Our same-day ltd company UK registration service locks your name within hours of completing our online application."}},
        {"@type":"Question","name":"Can a non-resident open a UK business bank account?","acceptedAnswer":{"@type":"Answer","text":"Yes. Digital banks like Wise Business, Revolut Business, and Payoneer allow remote account opening for non-residents. Our Banking Assistance service includes document preparation, pre-application review, and direct introductions to maximise approval likelihood."}}
      ]
    }
    <% } %>
    <% if (currentPath === '/uk-ltd-formation-for-non-residents') { %>
    ,{
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How to open a company in the UK as a non-resident?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Non-residents can open a UK company by using an authorized formation agent. You will need to provide basic company details, appoint directors and shareholders (no UK residency required), and have a UK registered office address."
          }
        },
        {
          "@type": "Question",
          "name": "What are the legal requirements for a UK non-resident company?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Legal requirements include a unique company name, at least one director, at least one shareholder, a UK registered office address, and declaring any person with significant control (PSC) to Companies House."
          }
        },

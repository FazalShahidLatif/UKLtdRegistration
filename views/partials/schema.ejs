    <% if (currentPath === '/blog/can-i-register-a-uk-company-as-a-non-uk-resident') { %>
    ,{
      "@type": "Service",
      "name": "company registration in uk for non residents",
      "provider": {
        "@id": "<%= siteUrl %>/#organization"
      },
      "areaServed": "Worldwide",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "128",

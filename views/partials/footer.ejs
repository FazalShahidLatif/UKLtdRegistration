<!-- Exit-Intent Popup -->
<div id="exit-popup"
    class="fixed inset-0 z-[100] hidden items-center justify-center bg-gray-900/60 backdrop-blur-md p-4 overflow-y-auto">
    <div class="bg-white rounded-[3rem] max-w-lg w-full p-12 relative shadow-2xl scale-95 transition-all duration-500 opacity-0"
        id="popup-content">
        <button onclick="closeExitPopup()" aria-label="Close popup"
            class="absolute top-8 right-8 text-gray-400 hover:text-gray-900 transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
        <div class="text-center">
            <div class="w-20 h-20 bg-blue-50 text-brand-blue rounded-3xl mx-auto flex items-center justify-center mb-8">
                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                        d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                    </path>
                </svg>
            </div>
            <h3 class="text-3xl font-black text-gray-900 mb-4 tracking-tighter">Wait! Before you go...</h3>
            <p class="text-gray-500 font-medium mb-8 leading-relaxed">Download our <span
                    class="text-brand-blue font-bold">2026 UK Founder's Checklist</span>. 15 essential steps to
                launching successfully from day 1.</p>
            <form class="space-y-4">
                <input type="email" placeholder="Where should we send it?"
                    class="w-full p-5 bg-gray-50 border-none rounded-2xl text-sm font-medium focus:ring-2 focus:ring-brand-blue transition-all outline-none">
                <button type="submit"
                    class="w-full bg-brand-blue text-white p-5 rounded-2xl font-black tracking-widest text-xs uppercase hover:bg-brand-navy shadow-xl shadow-blue-100 transition-all">Send
                    Me The Checklist</button>
            </form>
            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-8">Zero Spam • Instant Download
            </p>
        </div>
    </div>
</div>

<!-- Social Proof Toast -->
<div id="social-proof" class="fixed bottom-8 left-8 z-[90] hidden">
    <div class="glass pl-4 pr-8 py-4 rounded-[2rem] flex items-center space-x-4 animate-slide-up">
        <div
            class="w-10 h-10 rounded-xl bg-brand-blue flex items-center justify-center text-white text-[10px] font-black uppercase">
            UK</div>
        <div>
            <p class="text-[10px] font-black text-gray-900 uppercase tracking-widest" id="sp-text">Sarah from London</p>
            <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest">Just registered a company • 2m ago
            </p>
        </div>
    </div>
</div>

<style>
    @keyframes slide-up {
        from {
            transform: translateY(100%) scale(0.9);
            opacity: 0;
        }

        to {
            transform: translateY(0) scale(1);
            opacity: 1;
        }
    }

    .animate-slide-up {
        animation: slide-up 0.5s cubic-bezier(0.23, 1, 0.32, 1) forwards;
    }
</style>



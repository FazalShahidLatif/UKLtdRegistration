    <footer class="bg-brand-navy text-white py-20 relative overflow-hidden">
        <!-- Decoration -->
        <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-96 h-96 bg-brand-blue/10 rounded-full blur-3xl"></div>
        
        <div class="container mx-auto px-4 relative z-10">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
                <div class="col-span-1 md:col-span-1">
                    <div class="mb-6">
                        <img src="/images/logo.png" alt="UK LTD Formation" class="h-10 w-auto brightness-0 invert opacity-90">
                    </div>
                    <p class="text-gray-400 text-sm font-medium leading-relaxed">The authoritative partner for global founders. 2026-ready, transparency-driven formations.</p>
                </div>
                <div>
                    <h4 class="text-xs font-black uppercase tracking-widest text-gray-500 mb-6">Quick Links</h4>
                    <ul class="space-y-3">
                        <li><a href="/" class="text-sm font-bold text-gray-300 hover:text-brand-blue transition">Home</a></li>
                        <li><a href="/uk-residents" class="text-sm font-bold text-gray-300 hover:text-brand-blue transition">UK Residents</a></li>
                        <li><a href="/us-citizens" class="text-sm font-bold text-gray-300 hover:text-brand-blue transition">US Citizens</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-xs font-black uppercase tracking-widest text-gray-500 mb-6">Support</h4>
                    <ul class="space-y-3">
                        <li><a href="/knowledge-hub" class="text-sm font-bold text-gray-300 hover:text-brand-blue transition">Knowledge Hub</a></li>
                        <li><a href="/faq" class="text-sm font-bold text-gray-300 hover:text-brand-blue transition">FAQ</a></li>
                        <li><a href="/contact" class="text-sm font-bold text-gray-300 hover:text-brand-blue transition">Contact</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-xs font-black uppercase tracking-widest text-gray-500 mb-6">Newsletter</h4>
                    <p class="text-gray-400 text-sm mb-6 font-medium">Join 5,000+ founders receiving weekly UK compliance insights.</p>
                    <form class="flex flex-col space-y-3">
                        <input type="email" placeholder="Email" class="bg-white/5 border border-white/10 p-4 rounded-xl w-full text-white text-sm focus:ring-2 focus:ring-brand-blue transition-all outline-none">
                        <button class="bg-brand-blue text-white p-4 rounded-xl font-black text-xs uppercase tracking-widest hover:bg-brand-blue/80 transition shadow-lg shadow-blue-900/40">Subscribe Now</button>
                    </form>
                </div>
            </div>
            <div class="border-t border-white/5 mt-20 pt-8 flex flex-col md:flex-row justify-between items-center text-gray-500 text-[10px] font-black uppercase tracking-widest gap-4">
                <p>&copy; <%= currentYear %> UK LTD Registration. Authorized Agent.</p>
                <div class="flex space-x-6">
                    <a href="/legal/privacy" class="hover:text-white transition">Privacy</a>
                    <a href="/legal/terms" class="hover:text-white transition">Terms</a>
                    <a href="/legal/cookies" class="hover:text-white transition">Cookies</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Exit-Intent Popup -->
    <div id="exit-popup" class="fixed inset-0 z-[100] hidden items-center justify-center bg-gray-900/60 backdrop-blur-md p-4 overflow-y-auto">
        <div class="bg-white rounded-[3rem] max-w-lg w-full p-12 relative shadow-2xl scale-95 transition-all duration-500 opacity-0" id="popup-content">
            <button onclick="closeExitPopup()" class="absolute top-8 right-8 text-gray-400 hover:text-gray-900 transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
            <div class="text-center">
                <div class="w-20 h-20 bg-blue-50 text-brand-blue rounded-3xl mx-auto flex items-center justify-center mb-8">
                    <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                </div>
                <h3 class="text-3xl font-black text-gray-900 mb-4 tracking-tighter">Wait! Before you go...</h3>
                <p class="text-gray-500 font-medium mb-8 leading-relaxed">Download our <span class="text-brand-blue font-bold">2026 UK Founder's Checklist</span>. 15 essential steps to launching successfully from day 1.</p>
                <form class="space-y-4">
                    <input type="email" placeholder="Where should we send it?" class="w-full p-5 bg-gray-50 border-none rounded-2xl text-sm font-medium focus:ring-2 focus:ring-brand-blue transition-all outline-none">
                    <button type="submit" class="w-full bg-brand-blue text-white p-5 rounded-2xl font-black tracking-widest text-xs uppercase hover:bg-brand-navy shadow-xl shadow-blue-100 transition-all">Send Me The Checklist</button>
                </form>
                <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-8">Zero Spam • Instant Download</p>
            </div>
        </div>
    </div>

    <!-- Social Proof Toast -->
    <div id="social-proof" class="fixed bottom-8 left-8 z-[90] hidden">
        <div class="glass pl-4 pr-8 py-4 rounded-[2rem] flex items-center space-x-4 animate-slide-up">
            <div class="w-10 h-10 rounded-xl bg-brand-blue flex items-center justify-center text-white text-[10px] font-black uppercase">UK</div>
            <div>
                <p class="text-[10px] font-black text-gray-900 uppercase tracking-widest" id="sp-text">Sarah from London</p>
                <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest">Just registered a company • 2m ago</p>
            </div>
        </div>
    </div>

    <style>
        @keyframes slide-up {
            from { transform: translateY(100%) scale(0.9); opacity: 0; }
            to { transform: translateY(0) scale(1); opacity: 1; }
        }
        .animate-slide-up { animation: slide-up 0.5s cubic-bezier(0.23, 1, 0.32, 1) forwards; }
    </style>

    <script>
        // Exit Intent Logic
        let popupShown = false;
        document.addEventListener('mouseleave', (e) => {
            if (e.clientY < 0 && !popupShown) {
                showExitPopup();
            }
        });

        function showExitPopup() {
            const popup = document.getElementById('exit-popup');
            const content = document.getElementById('popup-content');
            popup.classList.remove('hidden');
            popup.classList.add('flex');
            setTimeout(() => {
                content.classList.remove('scale-95', 'opacity-0');
            }, 10);
            popupShown = true;
        }

        function closeExitPopup() {
            const popup = document.getElementById('exit-popup');
            popup.classList.add('hidden');
            popup.classList.remove('flex');
        }

        // Social Proof Simulation
        const names = ["James from Leeds", "Aarav from Birmingham", "Elena from Manchester", "Michael from Bristol", "Wei from London", "Lucas from Cardiff"];
        const spToast = document.getElementById('social-proof');
        const spText = document.getElementById('sp-text');

        function showSocialProof() {
            const name = names[Math.floor(Math.random() * names.length)];
            spText.innerText = name;
            spToast.classList.remove('hidden');
            setTimeout(() => {
                spToast.classList.add('hidden');
            }, 5000);
        }

        // Show every 15-30 seconds
        setTimeout(() => {
            showSocialProof();
            setInterval(showSocialProof, 25000);
        }, 8000);
    </script>

    <script src="/js/main.js"></script>
    <%- include('chatbot-widget') %>
</body>
</html>

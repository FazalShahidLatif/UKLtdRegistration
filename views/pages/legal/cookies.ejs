<%- include('../../partials/header') %>
<%- include('../../partials/navigation') %>

<main class="py-24 bg-gray-50/50">
    <div class="max-w-4xl mx-auto px-6">
        <div class="mb-16">
            <span class="text-[10px] font-black uppercase tracking-[0.2em] text-brand-blue">Legal</span>
            <h1 class="text-5xl font-black text-gray-900 tracking-tight mt-2">Cookie Policy</h1>
            <p class="text-gray-500 mt-4 font-medium">Last updated: March 2026. This policy explains how we use cookies and similar technologies.</p>
        </div>
        <div class="space-y-8">
            <div class="bg-white rounded-[2rem] p-10 border border-gray-100 shadow-sm">
                <h2 class="text-2xl font-black text-gray-900 mb-4">What Are Cookies?</h2>
                <p class="text-gray-600 leading-relaxed">Cookies are small text files placed on your device when you visit our website. They help us provide a better experience by remembering your preferences and understanding how you use our site.</p>
            </div>
            <div class="bg-white rounded-[2rem] p-10 border border-gray-100 shadow-sm">
                <h2 class="text-2xl font-black text-gray-900 mb-6">Types of Cookies We Use</h2>
                <div class="space-y-6">
                    <% const cookieTypes = [
                        { name: 'Essential Cookies', color: 'bg-brand-blue', desc: 'Required for the website to function. These include your session cookie which keeps you logged in and remembers your shopping cart. They cannot be disabled.' },
                        { name: 'Analytics Cookies', color: 'bg-purple-500', desc: 'Help us understand how visitors interact with our website. We use anonymised data to improve our content and user experience.' },
                        { name: 'Marketing Cookies', color: 'bg-brand-green', desc: 'Used to track the effectiveness of our marketing campaigns. We may use retargeting cookies to show you relevant advertisements on other websites.' }
                    ]; %>
                    <% cookieTypes.forEach(c => { %>
                    <div class="flex items-start space-x-4">
                        <div class="w-3 h-3 <%= c.color %> rounded-full mt-1.5 flex-shrink-0"></div>
                        <div>
                            <p class="font-black text-gray-900"><%= c.name %></p>
                            <p class="text-gray-500 text-sm leading-relaxed mt-1"><%= c.desc %></p>
                        </div>
                    </div>
                    <% }); %>
                </div>
            </div>
            <div class="bg-white rounded-[2rem] p-10 border border-gray-100 shadow-sm">
                <h2 class="text-2xl font-black text-gray-900 mb-4">Managing Cookies</h2>
                <p class="text-gray-600 leading-relaxed">You can control cookies through your browser settings. Note that disabling essential cookies may affect site functionality. For more information, visit <a href="https://www.allaboutcookies.org" target="_blank" rel="nofollow noopener" class="text-brand-blue font-bold hover:underline">allaboutcookies.org</a>.</p>
            </div>
        </div>
    </div>
</main>

<%- include('../../partials/footer') %>

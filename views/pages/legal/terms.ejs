<%- include('../../partials/header') %>
<%- include('../../partials/navigation') %>

<main class="py-24 bg-gray-50/50">
    <div class="max-w-4xl mx-auto px-6">
        <div class="mb-16">
            <span class="text-[10px] font-black uppercase tracking-[0.2em] text-brand-blue">Legal</span>
            <h1 class="text-5xl font-black text-gray-900 tracking-tight mt-2">Terms of Service</h1>
            <p class="text-gray-500 mt-4 font-medium">Last updated: March 2026. By using our services you agree to these terms.</p>
        </div>

        <div class="space-y-8">
            <% const sections = [
                { title: '1. Service Agreement', body: 'UK Ltd Registration provides company formation and related business services. By placing an order, you enter into a binding agreement subject to these terms. Our services are available to individuals aged 18 and over.' },
                { title: '2. The Formation Service', body: 'We act as an authorized agent to submit your company formation application to Companies House. The £100 statutory filing fee (as of February 2026) is included in all our packages and is non-refundable once submitted. For details on our regulatory obligations, see our <a href="/legal/compliance" class="text-brand-blue font-bold hover:underline">Compliance & GDPR</a> page.' },
                { title: '3. Your Responsibilities', body: 'You are responsible for providing accurate information for your application. Providing false information to Companies House is a criminal offence under the Companies Act 2006. You must also comply with all ongoing legal obligations as a company director, including filing Annual Returns and confirming your Statement of Capital.' },
                { title: '4. Refund & Cancellation', body: 'Our refund policy is designed to be fair and transparent while accounting for non-recoverable government fees and administrative costs. Please read our full <a href="/legal/refund" class="text-brand-blue font-bold hover:underline">Refund Policy</a> for detailed information on non-refundable amounts and claim timeframes.' },
                { title: '5. Intellectual Property', body: 'All content on this website, including guides, templates, and tools, is the intellectual property of UK Ltd Registration and may not be reproduced without express written permission.' },
                { title: '6. Limitation of Liability', body: 'We are not liable for any indirect, incidental, or consequential damages arising from the use of our services. Our total liability for any claim arising from a service is limited to the amount paid for that service.' },
                { title: '7. Governing Law & Compliance', body: 'These terms are governed by the laws of England and Wales. We operate in full compliance with UK Money Laundering Regulations 2017 and UK GDPR. Any disputes shall be subject to the exclusive jurisdiction of the courts of England and Wales.' },
                { title: '8. Changes to Terms', body: 'We may update these terms from time to time. We will notify registered users of material changes via email. Continued use of our services after notification constitutes acceptance of the updated terms.' }
            ]; %>
            <% sections.forEach(s => { %>
            <div class="bg-white rounded-[2rem] p-10 border border-gray-100 shadow-sm">
                <h2 class="text-2xl font-black text-gray-900 mb-4"><%= s.title %></h2>
                <p class="text-gray-600 leading-relaxed"><%= s.body %></p>
            </div>
            <% }); %>
        </div>
    </div>
</main>

<%- include('../../partials/footer') %>

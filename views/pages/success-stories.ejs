<%- include('../partials/header') %>
<%- include('../partials/navigation') %>

<main class="bg-white pt-32 pb-24">
    <!-- Hero Section -->
    <section class="container mx-auto px-4 mb-32 text-center">
        <div class="inline-flex items-center space-x-2 px-4 py-2 bg-blue-50 border border-blue-100 rounded-full mb-8">
            <div class="w-2 h-2 bg-brand-blue rounded-full animate-pulse"></div>
            <span class="text-[10px] font-black uppercase tracking-widest text-brand-blue">Global Impact: 2026</span>
        </div>
        <h1 class="text-6xl md:text-8xl font-black text-gray-900 mb-8 tracking-tighter leading-tight">
            Pakistani Founders <br/><span class="text-brand-blue">Going Global.</span>
        </h1>
        <p class="text-2xl text-gray-500 max-w-3xl mx-auto font-medium leading-relaxed">
            Real stories of entrepreneurs, freelancers, and traders who bypassed local limitations to build international brands with a UK Limited Company.
        </p>
    </section>

    <!-- Success Story 1: The Amazon FBA Titan -->
    <section class="container mx-auto px-4 mb-40">
        <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16">
            <div class="lg:w-1/2 rounded-[3rem] overflow-hidden shadow-2xl relative group">
                <div class="absolute inset-0 bg-brand-blue/10 mix-blend-overlay group-hover:opacity-0 transition duration-700"></div>
                <img src="/images/success/fba.png" alt="Zainab from Lahore - Amazon FBA Success" class="w-full h-auto object-cover scale-105 group-hover:scale-100 transition duration-700">
            </div>
            <div class="lg:w-1/2">
                <div class="inline-block px-4 py-1.5 mb-6 bg-green-50 text-green-600 rounded-xl text-[10px] font-black uppercase tracking-widest">Amazon FBA & E-commerce</div>
                <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-6 tracking-tight">How Zainab Scaled her Lahore Workshop to the UK & EU.</h2>
                <p class="text-lg text-gray-600 font-medium leading-relaxed mb-8">
                    "I was struggling with local FX conversion losses and the inability to access European Amazon warehouses. By forming a **UK Limited Company**, I gained immediate access to Amazon Global Selling. Today, my Lahore-manufactured goods are Best Sellers in the UK, and I manage everything from my phone in Gulberg."
                </p>
                <div class="grid grid-cols-2 gap-8 py-8 border-y border-gray-100 mb-8">
                    <div>
                        <p class="text-3xl font-black text-brand-blue">£150k+</p>
                        <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mt-1">Annual Revenue</p>
                    </div>
                    <div>
                        <p class="text-3xl font-black text-brand-blue">24h</p>
                        <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mt-1">Faster Payouts</p>
                    </div>
                </div>
                <blockquote class="text-xl font-bold italic text-gray-900 border-l-4 border-brand-blue pl-6">
                    "The UK LTD is the gold standard for Pakistani exporters. It removed all my banking hurdles overnight."
                </blockquote>
            </div>
        </div>
    </section>

    <!-- Success Story 2: The SaaS Architect -->
    <section class="container mx-auto px-4 mb-40">
        <div class="max-w-7xl mx-auto flex flex-col lg:flex-row-reverse items-center gap-16">
            <div class="lg:w-1/2 rounded-[3rem] overflow-hidden shadow-2xl relative group">
                <div class="absolute inset-0 bg-indigo-900/10 mix-blend-overlay group-hover:opacity-0 transition duration-700"></div>
                <img src="/images/success/saas.png" alt="Ahmed from Faisalabad - SaaS Founder" class="w-full h-auto object-cover scale-105 group-hover:scale-100 transition duration-700">
            </div>
            <div class="lg:w-1/2">
                <div class="inline-block px-4 py-1.5 mb-6 bg-indigo-50 text-indigo-600 rounded-xl text-[10px] font-black uppercase tracking-widest">SaaS & Fintech</div>
                <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-6 tracking-tight">Ahmed's AI Startup: From Faisalabad to Global Funding.</h2>
                <p class="text-lg text-gray-600 font-medium leading-relaxed mb-8">
                    "We built a world-class AI EdTech tool, but we couldn't accept global card payments. Stripe and PayPal weren't an option from Pakistan. Our **UK LTD** allowed us to integrate a full payment stack in 48 hours. We recently closed our first seed round from a London-based VC firm—something that would be impossible with a local entity."
                </p>
                <div class="grid grid-cols-2 gap-8 py-8 border-y border-gray-100 mb-8">
                    <div>
                        <p class="text-3xl font-black text-indigo-600">$5k+</p>
                        <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mt-1">Monthly Recurring (MRR)</p>
                    </div>
                    <div>
                        <p class="text-3xl font-black text-indigo-600">ZERO</p>
                        <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mt-1">Payment Friction</p>
                    </div>
                </div>
                <blockquote class="text-xl font-bold italic text-gray-900 border-l-4 border-indigo-600 pl-6">
                    "A UK company is the universal passport for software founders in Pakistan."
                </blockquote>
            </div>
        </div>
    </section>

    <!-- Success Story 3: The High-Ticket Freelancer -->
    <section class="container mx-auto px-4 mb-40">
        <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16">
            <div class="lg:w-1/2 rounded-[3rem] overflow-hidden shadow-2xl relative group">
                <div class="absolute inset-0 bg-brand-blue/10 mix-blend-overlay group-hover:opacity-0 transition duration-700"></div>
                <img src="/images/success/freelancer.png" alt="Hamza from Karachi - Senior Developer" class="w-full h-auto object-cover scale-105 group-hover:scale-100 transition duration-700">
            </div>
            <div class="lg:w-1/2">
                <div class="inline-block px-4 py-1.5 mb-6 bg-blue-50 text-brand-blue rounded-xl text-[10px] font-black uppercase tracking-widest">Freelance & Consulting</div>
                <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-6 tracking-tight">Bypassing Payment Blocks: Hamza's $10k+ Monthly Milestone.</h2>
                <p class="text-lg text-gray-600 font-medium leading-relaxed mb-8">
                    "Large international clients in the US and UK often hesitate to bank-transfer directly to Pakistan due to compliance paperwork. My **UK LTD** and **Wise Business** account solved this. I now charge high-ticket rates as a 'UK Company Owner', which has increased my closing rate by 40%."
                </p>
                <div class="grid grid-cols-2 gap-8 py-8 border-y border-gray-100 mb-8">
                    <div>
                        <p class="text-3xl font-black text-brand-blue">40%</p>
                        <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mt-1">Higher Conversion</p>
                    </div>
                    <div>
                        <p class="text-3xl font-black text-brand-blue">SECURE</p>
                        <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mt-1">GBP Invoicing</p>
                    </div>
                </div>
                <blockquote class="text-xl font-bold italic text-gray-900 border-l-4 border-brand-blue pl-6">
                    "I stopped being a 'cheap resource' and started being an 'International Partner'."
                </blockquote>
            </div>
        </div>
    </section>

    <!-- Success Story 4: The Trader -->
    <section class="container mx-auto px-4 mb-32">
        <div class="max-w-7xl mx-auto flex flex-col lg:flex-row-reverse items-center gap-16">
            <div class="lg:w-1/2 rounded-[3rem] overflow-hidden shadow-2xl relative group">
                <div class="absolute inset-0 bg-gray-900/10 mix-blend-overlay group-hover:opacity-0 transition duration-700"></div>
                <img src="/images/success/trader.png" alt="Farhan from Islamabad - Professional Trader" class="w-full h-auto object-cover scale-105 group-hover:scale-100 transition duration-700">
            </div>
            <div class="lg:w-1/2">
                <div class="inline-block px-4 py-1.5 mb-6 bg-gray-100 text-gray-600 rounded-xl text-[10px] font-black uppercase tracking-widest">Forex & Crypto Trading</div>
                <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-6 tracking-tight">Institutional-Grade Banking: Farhan's Trading Gateway.</h2>
                <p class="text-lg text-gray-600 font-medium leading-relaxed mb-8">
                    "Dealing with prop-firm payouts and crypto-exchanges from Islamabad was a compliance nightmare with local banks. My **UK LTD** provided me with a clean, institutional-grade banking setup in London. Withdrawals to my Wise account are instant, and I have total peace of mind for my tax and regulatory compliance."
                </p>
                <div class="grid grid-cols-2 gap-8 py-8 border-y border-gray-100 mb-8">
                    <div>
                        <p class="text-3xl font-black text-gray-900">INSTANT</p>
                        <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mt-1">Exchange Payouts</p>
                    </div>
                    <div>
                        <p class="text-3xl font-black text-gray-900">ACSP</p>
                        <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mt-1">2026 Verified</p>
                    </div>
                </div>
                <blockquote class="text-xl font-bold italic text-gray-900 border-l-4 border-gray-900 pl-6">
                    "For serious traders in Pakistan, a UK company is the ultimate shield and sword."
                </blockquote>
            </div>
        </div>
    </section>

    <!-- Call to Action -->
    <section class="py-32 bg-brand-navy text-white text-center">
        <div class="container mx-auto px-4">
            <h2 class="text-5xl md:text-7xl font-black mb-8 tracking-tighter">Ready to be our next <br/><span class="text-brand-blue">Success Story?</span></h2>
            <p class="text-xl text-gray-400 font-medium mb-12 max-w-2xl mx-auto leading-relaxed">Join 5,000+ Pakistani founders building their global legacy from home.</p>
            <div class="flex flex-col md:flex-row justify-center gap-6">
                <a href="/pricing" class="btn-primary">View Global Packages</a>
                <a href="/contact" class="px-10 py-5 bg-white/10 hover:bg-white/20 text-white rounded-2xl font-black text-xs uppercase tracking-widest transition backdrop-blur-md border border-white/10">Speak to an Advisor</a>
            </div>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>

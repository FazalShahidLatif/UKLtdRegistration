<%- include('../partials/header') %>
<%- include('../partials/navigation') %>

<main class="min-h-screen pt-12 pb-24">
    <!-- Hero -->
    <section class="max-w-7xl mx-auto px-4 py-20 text-center">
        <div class="inline-block px-4 py-1.5 mb-8 bg-brand-blue/10 text-brand-blue rounded-full text-xs font-black tracking-widest uppercase">
            Contact Us
        </div>
        <h1 class="text-5xl md:text-6xl font-black text-gray-900 mb-6 tracking-tighter">
            We're Here to <span class="text-brand-blue">Help You.</span>
        </h1>
        <p class="text-xl text-gray-500 max-w-xl mx-auto font-medium">
            Whether you have questions about formation, compliance, or our services — our team is ready.
        </p>
    </section>

    <!-- Contact Grid -->
    <section class="max-w-7xl mx-auto px-4 pb-24">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

            <!-- Contact Info Side -->
            <div class="lg:col-span-2 space-y-6">
                <div class="glass p-8 rounded-[2.5rem]">
                    <div class="w-12 h-12 bg-blue-50 text-brand-blue rounded-xl flex items-center justify-center mb-5">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    </div>
                    <h3 class="font-black text-gray-900 mb-2">Email Support</h3>
                    <p class="text-gray-500 text-sm font-medium mb-1">General Enquiries</p>
                    <a href="mailto:hello@ukltdregistration.com" class="text-brand-blue font-bold text-sm hover:underline">hello@ukltdregistration.com</a>
                </div>
                <div class="glass p-8 rounded-[2.5rem]">
                    <div class="w-12 h-12 bg-green-50 text-brand-green rounded-xl flex items-center justify-center mb-5">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                    </div>
                    <h3 class="font-black text-gray-900 mb-2">Phone</h3>
                    <p class="text-gray-500 text-sm font-medium mb-1">Mon–Fri, 9am–6pm (UK)</p>
                    <a href="tel:+442012345678" class="text-brand-green font-bold text-sm hover:underline">+44 20 1234 5678</a>
                </div>
                <div class="glass p-8 rounded-[2.5rem]">
                    <div class="w-12 h-12 bg-purple-50 text-purple-600 rounded-xl flex items-center justify-center mb-5">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    </div>
                    <h3 class="font-black text-gray-900 mb-2">Registered Address</h3>
                    <p class="text-gray-500 text-sm font-medium leading-relaxed">UK Ltd Registration Ltd<br>71-75 Shelton Street<br>Covent Garden, London<br>WC2H 9JQ</p>
                </div>
                <div class="glass p-8 rounded-[2.5rem]">
                    <h3 class="font-black text-gray-900 mb-4">Response Times</h3>
                    <div class="space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="text-sm font-medium text-gray-500">Live Chat</span>
                            <span class="text-xs font-black text-brand-green bg-green-50 px-3 py-1 rounded-full">Under 5 mins</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-sm font-medium text-gray-500">Email</span>
                            <span class="text-xs font-black text-brand-blue bg-blue-50 px-3 py-1 rounded-full">Same Day</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-sm font-medium text-gray-500">Phone</span>
                            <span class="text-xs font-black text-gray-500 bg-gray-100 px-3 py-1 rounded-full">Mon–Fri 9–6 UK</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="lg:col-span-3">
                <div class="bg-white p-10 rounded-[2.5rem] shadow-sm border border-gray-100">
                    <h2 class="text-2xl font-black text-gray-900 mb-2">Send Us a Message</h2>
                    <p class="text-gray-500 text-sm font-medium mb-8">We'll get back to you within one business day.</p>
                    <form action="/api/contact" method="POST" class="space-y-6" id="contact-form">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-[10px] font-black uppercase tracking-widest text-gray-500 mb-2">First Name</label>
                                <input type="text" name="firstName" required class="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-2xl text-sm font-medium focus:ring-2 focus:ring-brand-blue outline-none transition-all" placeholder="John">
                            </div>
                            <div>
                                <label class="block text-[10px] font-black uppercase tracking-widest text-gray-500 mb-2">Last Name</label>
                                <input type="text" name="lastName" required class="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-2xl text-sm font-medium focus:ring-2 focus:ring-brand-blue outline-none transition-all" placeholder="Smith">
                            </div>
                        </div>
                        <div>
                            <label class="block text-[10px] font-black uppercase tracking-widest text-gray-500 mb-2">Email Address</label>
                            <input type="email" name="email" required class="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-2xl text-sm font-medium focus:ring-2 focus:ring-brand-blue outline-none transition-all" placeholder="you@example.com">
                        </div>
                        <div>
                            <label class="block text-[10px] font-black uppercase tracking-widest text-gray-500 mb-2">Topic</label>
                            <select name="topic" class="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-2xl text-sm font-medium focus:ring-2 focus:ring-brand-blue outline-none transition-all appearance-none cursor-pointer">
                                <option value="">Select a topic...</option>
                                <option value="formation">Company Formation</option>
                                <option value="compliance">Compliance & 2026 Changes</option>
                                <option value="accounting">Accounting & Tax</option>
                                <option value="banking">Business Banking</option>
                                <option value="virtual-office">Virtual Office & Address</option>
                                <option value="affiliate">Affiliate / Partner Program</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-[10px] font-black uppercase tracking-widest text-gray-500 mb-2">Message</label>
                            <textarea name="message" rows="5" required class="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-2xl text-sm font-medium focus:ring-2 focus:ring-brand-blue outline-none transition-all resize-none" placeholder="Tell us how we can help..."></textarea>
                        </div>
                        <button type="submit" class="btn-primary w-full">Send Message</button>
                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest text-center">We respect your privacy. No spam — ever.</p>
                    </form>
                    <div id="contact-success" class="hidden text-center py-12">
                        <div class="w-16 h-16 bg-green-50 text-brand-green rounded-2xl flex items-center justify-center mx-auto mb-6">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <h3 class="text-2xl font-black text-gray-900 mb-3">Message Sent!</h3>
                        <p class="text-gray-500 font-medium">We'll be in touch within one business day.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<script>
    document.getElementById('contact-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        const btn = this.querySelector('button[type=submit]');
        btn.textContent = 'Sending...';
        btn.disabled = true;

        try {
            const res = await fetch('/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(Object.fromEntries(new FormData(this)))
            });
            document.getElementById('contact-form').classList.add('hidden');
            document.getElementById('contact-success').classList.remove('hidden');
        } catch(err) {
            btn.textContent = 'Send Message';
            btn.disabled = false;
            alert('Something went wrong. Please try emailing us directly.');
        }
    });
</script>

<%- include('../partials/footer') %>

<%- include('../partials/header') %>
<%- include('../partials/navigation') %>

<!-- JSON-LD LocalBusiness Schema Markup -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "UK Ltd Registration",
  "image": "https://ukltdregistration.com/images/hero-pricing.jpg",
  "@id": "https://ukltdregistration.com/#localbusiness",
  "url": "https://ukltdregistration.com",
  "telephone": "+442031234567",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "71-75 Shelton Street, Covent Garden",
    "addressLocality": "London",
    "postalCode": "WC2H 9JQ",
    "addressCountry": "GB"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 51.5148,
    "longitude": -0.1235
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday"
    ],
    "opens": "09:00",
    "closes": "17:00"
  },
  "sameAs": [
    "https://www.facebook.com/ukltdregistration",
    "https://twitter.com/ukltdregistration",
    "https://www.linkedin.com/company/ukltdregistration"
  ]
}
</script>

<main class="bg-gray-50/50 min-h-screen pt-32 pb-24">
    <!-- Hero Section -->
    <section class="container mx-auto px-4 mb-20 text-center">
        <div class="inline-flex items-center space-x-2 px-4 py-2 bg-blue-50 border border-blue-100 rounded-full mb-8">
            <div class="w-2 h-2 bg-brand-blue rounded-full animate-pulse"></div>
            <span class="text-[10px] font-black uppercase tracking-widest text-brand-blue">Global Operations & Support</span>
        </div>
        <h1 class="text-5xl md:text-7xl font-black text-gray-900 mb-6 tracking-tight leading-tight">
            Let's Build Your <br/><span class="text-brand-blue">Global Vision.</span>
        </h1>
        <p class="text-xl text-gray-500 max-w-2xl mx-auto font-medium leading-relaxed">
            Our strategic advisors are ready to help you navigate the UK business landscape from anywhere in the world.
        </p>
    </section>

    <!-- Contact Content Grid -->
    <section class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
            
            <!-- Contact Form -->
            <div class="p-10 md:p-12 rounded-[2.5rem] bg-white border border-gray-100 shadow-2xl">
                <h2 class="text-3xl font-black text-gray-900 mb-8 tracking-tight">Direct Inquiry</h2>
                <form action="#" class="space-y-6" id="secure-contact-form">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">Full Name</label>
                            <input type="text" placeholder="John Doe" required class="w-full p-5 bg-gray-50 border-none rounded-2xl text-sm font-medium focus:ring-2 focus:ring-brand-blue transition-all outline-none">
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">Business Email</label>
                            <input type="email" placeholder="john@company.com" required class="w-full p-5 bg-gray-50 border-none rounded-2xl text-sm font-medium focus:ring-2 focus:ring-brand-blue transition-all outline-none">
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">Subject</label>
                        <select class="w-full p-5 bg-gray-50 border-none rounded-2xl text-sm font-medium focus:ring-2 focus:ring-brand-blue transition-all outline-none appearance-none">
                            <option>New Company Formation</option>
                            <option>Tax & Accounting Support</option>
                            <option>Business Banking Help</option>
                            <option>Technical Issue</option>
                            <option>Other / General Inquiry</option>
                        </select>
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">Message</label>
                        <textarea rows="5" placeholder="How can our agents assist you today?" required class="w-full p-5 bg-gray-50 border-none rounded-2xl text-sm font-medium focus:ring-2 focus:ring-brand-blue transition-all outline-none resize-none"></textarea>
                    </div>
                    <button type="submit" class="w-full py-5 bg-brand-blue text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-blue-700 transition shadow-xl shadow-blue-200">
                        Send Strategic Message
                    </button>
                    <p class="text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-6">Secure • Encrypted • response in &lt; 2 hours</p>
                </form>
            </div>

            <!-- Contact Info & Details -->
            <div class="space-y-8 h-full">
                <!-- Info Card 1: Phone / Support -->
                <div class="bg-white rounded-[2.5rem] p-10 border border-gray-100 shadow-xl hover:-translate-y-1 transition duration-500">
                    <div class="flex items-center space-x-6">
                        <div class="w-16 h-16 bg-blue-50 text-brand-blue rounded-3xl flex items-center justify-center">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mb-2">UK Landline Support</h4>
                            <p class="text-2xl font-black text-gray-900">+44 (0) 20 3123 4567</p>
                            <p class="text-xs font-bold text-brand-blue uppercase tracking-widest mt-1">Monday – Friday, 09:00 – 17:00 GMT</p>
                        </div>
                    </div>
                </div>

                <!-- Info Card 2: Registered Address -->
                <div class="bg-white rounded-[2.5rem] p-10 border border-gray-100 shadow-xl hover:-translate-y-1 transition duration-500">
                    <div class="flex items-start space-x-6">
                        <div class="w-16 h-16 bg-indigo-50 text-indigo-600 rounded-3xl flex items-center justify-center shrink-0">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mb-3">UK Registered Address</h4>
                            <p class="text-xl font-bold text-gray-900 leading-snug">
                                71-75 Shelton Street,<br/>
                                Covent Garden,<br/>
                                London, WC2H 9JQ, UK
                            </p>
                            <p class="text-xs font-bold text-gray-500 mt-4 leading-relaxed">Official physical street registered office address.</p>
                        </div>
                    </div>
                </div>

                <!-- Info Card 3: Email Coverage -->
                <div class="bg-white rounded-[2.5rem] p-10 border border-gray-100 shadow-xl hover:-translate-y-1 transition duration-500">
                    <div class="flex items-center space-x-6">
                        <div class="w-16 h-16 bg-green-50 text-green-600 rounded-3xl flex items-center justify-center">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mb-2">Corporate Correspondence</h4>
                            <p class="text-xl font-black text-gray-900">support@ukltdregistration.com</p>
                            <p class="text-xs font-bold text-gray-500 mt-1 uppercase tracking-widest">Global 24/7 Ticketing System</p>
                        </div>
                    </div>
                </div>

                <!-- Live Chat Placeholder & Social Links -->
                <div class="bg-brand-navy rounded-[2.5rem] p-10 text-white relative overflow-hidden group">
                    <div class="absolute top-0 right-0 -mr-10 -mt-10 w-40 h-40 bg-brand-blue/20 rounded-full blur-3xl transition-all duration-700 group-hover:scale-150"></div>
                    <div class="relative z-10 flex items-center justify-between mb-6">
                        <h4 class="text-xl font-black">Live Chat Support</h4>
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-[9px] font-black tracking-widest bg-emerald-500/25 text-emerald-400 uppercase">
                            <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full mr-2 animate-ping"></span>
                            Online
                        </span>
                    </div>
                    <p class="text-gray-400 text-sm font-medium mb-6 relative z-10">Connect instantly with our corporate registration specialists for quick real-time answers.</p>
                    <div class="flex items-center gap-6 relative z-10">
                        <a href="https://www.facebook.com/ukltdregistration" target="_blank" class="text-gray-400 hover:text-white transition">Facebook</a>
                        <a href="https://twitter.com/ukltdregistration" target="_blank" class="text-gray-400 hover:text-white transition">Twitter</a>
                        <a href="https://www.linkedin.com/company/ukltdregistration" target="_blank" class="text-gray-400 hover:text-white transition">LinkedIn</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>
<%- include('../../partials/header') %>
<%- include('../../partials/navigation') %>

<main class="min-h-screen pt-12 pb-24 bg-gray-50/50">
    <div class="max-w-7xl mx-auto px-4">
        <!-- Hero -->
        <div class="text-center pt-20 mb-16">
            <div class="inline-block px-4 py-1.5 mb-6 bg-brand-blue/10 text-brand-blue rounded-full text-xs font-black tracking-widest uppercase">Professional Space</div>
            <h1 class="text-5xl font-black text-gray-900 mb-6 tracking-tight">Professional Meeting Rooms<br>in Central London</h1>
            <p class="text-xl text-gray-600 max-w-2xl mx-auto">Impress your clients and close deals in our state-of-the-art boardrooms. Flexible booking, elite facilities, professional reception.</p>
        </div>

        <!-- Features Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100 text-center">
                <div class="text-3xl mb-4">☕</div>
                <h3 class="font-black text-gray-900 mb-2">Refreshments</h3>
                <p class="text-gray-500 text-sm font-medium">Unlimited tea, coffee, water & soft drinks for all attendees.</p>
            </div>
            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100 text-center">
                <div class="text-3xl mb-4">📺</div>
                <h3 class="font-black text-gray-900 mb-2">4K Displays</h3>
                <p class="text-gray-500 text-sm font-medium">65" 4K presentation screens with wireless casting.</p>
            </div>
            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100 text-center">
                <div class="text-3xl mb-4">🌐</div>
                <h3 class="font-black text-gray-900 mb-2">Ultra-Fast Wi-Fi</h3>
                <p class="text-gray-500 text-sm font-medium">1Gbps dedicated fibre. Secure guest network included.</p>
            </div>
            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100 text-center">
                <div class="text-3xl mb-4">👩‍💼</div>
                <h3 class="font-black text-gray-900 mb-2">Reception Staff</h3>
                <p class="text-gray-500 text-sm font-medium">Professional reception team to greet your guests.</p>
            </div>
        </div>

        <!-- Pricing -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100">
                <h3 class="text-xl font-black text-gray-900 mb-2">Hourly</h3>
                <p class="text-4xl font-black text-brand-blue mb-4">£30<span class="text-sm text-gray-400 font-medium">/hr</span></p>
                <p class="text-gray-500 text-sm font-medium mb-6">Minimum 1 hour. Ideal for quick client meetings or interviews.</p>
                <ul class="space-y-2 text-sm text-gray-500 font-medium mb-8">
                    <li>✔ Up to 6 people</li>
                    <li>✔ Refreshments included</li>
                    <li>✔ Wi-Fi & AV included</li>
                </ul>
                <a href="/contact" class="block text-center bg-gray-900 text-white py-3 rounded-xl font-bold hover:bg-gray-800 transition">Enquire to Book</a>
            </div>
            <div class="bg-brand-blue p-8 rounded-[2.5rem] shadow-xl border border-blue-400 text-white">
                <div class="flex justify-between items-center mb-2">
                    <h3 class="text-xl font-black">Half Day</h3>
                    <span class="bg-white text-brand-blue text-xs font-bold px-2 py-1 rounded">Popular</span>
                </div>
                <p class="text-4xl font-black mb-4">£110<span class="text-sm text-blue-200 font-medium">/4hrs</span></p>
                <p class="text-blue-100 text-sm font-medium mb-6">4 consecutive hours. Great for workshops, strategy sessions, or board meetings.</p>
                <ul class="space-y-2 text-sm text-blue-100 font-medium mb-8">
                    <li>✔ Up to 12 people</li>
                    <li>✔ Complimentary lunch available</li>
                    <li>✔ Whiteboard & flip chart</li>
                    <li>✔ Video conferencing set-up</li>
                </ul>
                <a href="/contact" class="block text-center bg-white text-brand-blue py-3 rounded-xl font-bold hover:bg-gray-100 transition shadow-lg">Enquire to Book</a>
            </div>
            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100">
                <h3 class="text-xl font-black text-gray-900 mb-2">Full Day</h3>
                <p class="text-4xl font-black text-brand-blue mb-4">£199<span class="text-sm text-gray-400 font-medium">/day</span></p>
                <p class="text-gray-500 text-sm font-medium mb-6">8 hours. Perfect for training days, all-hands meetings, or pitch sessions.</p>
                <ul class="space-y-2 text-sm text-gray-500 font-medium mb-8">
                    <li>✔ Up to 20 people</li>
                    <li>✔ Morning & afternoon refreshments</li>
                    <li>✔ Dedicated AV technician</li>
                    <li>✔ Branded welcome screen</li>
                </ul>
                <a href="/contact" class="block text-center bg-gray-900 text-white py-3 rounded-xl font-bold hover:bg-gray-800 transition">Enquire to Book</a>
            </div>
        </div>

        <!-- CTA -->
        <div class="bg-brand-navy rounded-[3rem] p-12 text-center text-white mb-16">
            <h2 class="text-3xl font-black mb-4 tracking-tighter">Reserve Your Room Today</h2>
            <p class="text-gray-400 font-medium mb-8 max-w-xl mx-auto">Availability is limited. Contact our team to check availability and confirm your booking. Premium package members receive 2 free hours per month.</p>
            <a href="/contact" class="btn-primary inline-block">Check Availability</a>
        </div>
    </div>
</main>

<%- include('../../partials/footer') %>

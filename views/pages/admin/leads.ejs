<%- include('../../partials/header') %>
<%- include('../../partials/navigation') %>

<main class="bg-gray-50 min-h-screen pt-24 pb-12">
    <div class="container mx-auto px-4">
        <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
            <div>
                <h1 class="text-3xl font-black text-gray-900 tracking-tight">Auto-Lead <span class="text-blue-600">Generator</span></h1>
                <p class="text-gray-500 mt-1">Harnessing Companies House public records for strategic growth.</p>
            </div>
            <button id="fetchLeadsBtn" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-bold transition-all shadow-lg shadow-blue-200 flex items-center justify-center space-x-2 whitespace-nowrap">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                <span>Fetch Daily Leads</span>
            </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
            <div class="bg-white p-6 rounded-[2rem] border border-gray-100 shadow-sm">
                <p class="text-xs font-black text-gray-400 uppercase tracking-widest mb-1">Total Captured</p>
                <p class="text-3xl font-black text-gray-900"><%= leads.length %></p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-gray-100 shadow-sm">
                <p class="text-xs font-black text-gray-400 uppercase tracking-widest mb-1">Critical Leads</p>
                <p class="text-3xl font-black text-red-600"><%= leads.filter(l => l.opportunityScore > 40).length %></p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-gray-100 shadow-sm">
                <p class="text-xs font-black text-gray-400 uppercase tracking-widest mb-1">New Companies</p>
                <p class="text-3xl font-black text-blue-600"><%= leads.filter(l => l.opportunityType.includes('New Incorporation')).length %></p>
            </div>
        </div>

        <div class="bg-white/70 backdrop-blur-xl rounded-[2.5rem] border border-white shadow-2xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-gray-50/50 border-b border-gray-100">
                            <th class="px-8 py-6 text-xs font-black text-gray-400 uppercase tracking-widest">Company</th>
                            <th class="px-8 py-6 text-xs font-black text-gray-400 uppercase tracking-widest">Opportunity</th>
                            <th class="px-8 py-6 text-xs font-black text-gray-400 uppercase tracking-widest">Score</th>
                            <th class="px-8 py-6 text-xs font-black text-gray-400 uppercase tracking-widest">Due Dates</th>
                            <th class="px-8 py-6 text-xs font-black text-gray-400 uppercase tracking-widest text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        <% if (leads.length > 0) { %>
                            <% leads.forEach(lead => { %>
                                <tr class="hover:bg-blue-50/30 transition-colors">
                                    <td class="px-8 py-6">
                                        <div class="font-black text-gray-900 leading-none"><%= lead.companyName %></div>
                                        <div class="text-xs text-gray-400 mt-1 uppercase font-bold tracking-tighter"><%= lead.companyNumber %></div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <div class="flex flex-wrap gap-2">
                                            <% lead.opportunityType.forEach(type => { %>
                                                <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-[10px] font-black uppercase tracking-tighter">
                                                    <%= type %>
                                                </span>
                                            <% }) %>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <div class="flex items-center space-x-2">
                                            <div class="w-12 h-2 bg-gray-100 rounded-full overflow-hidden">
                                                <div class="h-full <%= lead.opportunityScore > 40 ? 'bg-red-500' : 'bg-blue-500' %>" style="width: <%= Math.min(lead.opportunityScore, 100) %>%"></div>
                                            </div>
                                            <span class="text-sm font-black text-gray-700"><%= lead.opportunityScore %></span>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <div class="text-xs space-y-1">
                                            <p class="<%= lead.accountsOverdue ? 'text-red-500 font-bold' : 'text-gray-500' %>">
                                                Accounts: <%= lead.accountsDueDate ? new Date(lead.accountsDueDate).toLocaleDateString() : 'N/A' %>
                                            </p>
                                            <p class="<%= lead.confirmationStatementOverdue ? 'text-red-500 font-bold' : 'text-gray-500' %>">
                                                Confirm: <%= lead.confirmationStatementDueDate ? new Date(lead.confirmationStatementDueDate).toLocaleDateString() : 'N/A' %>
                                            </p>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6 text-right">
                                        <button onclick="deleteLead('<%= lead._id %>')" class="p-2 text-gray-400 hover:text-red-600 transition-colors">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="px-8 py-20 text-center">
                                    <div class="text-gray-300 mb-4">
                                        <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
                                    </div>
                                    <p class="text-xl font-black text-gray-900">No Leads Found</p>
                                    <p class="text-gray-500">Click "Fetch Daily Leads" to start scanning Companies House.</p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<script>
    document.getElementById('fetchLeadsBtn').addEventListener('click', async function() {
        const btn = this;
        const originalText = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> <span>Processing...</span>';
        
        try {
            const response = await fetch('/admin/leads/fetch', { method: 'POST' });
            const data = await response.json();
            if (data.success) {
                alert(`Successfully processed ${data.results.processed} leads. ${data.results.new} new leads found.`);
                window.location.reload();
            } else {
                alert('Error fetching leads: ' + data.error);
            }
        } catch (error) {
            alert('An unexpected error occurred.');
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalText;
        }
    });

    async function deleteLead(id) {
        if (confirm('Are you sure you want to remove this lead?')) {
            const response = await fetch(`/admin/leads/${id}`, { method: 'DELETE' });
            if (response.ok) {
                window.location.reload();
            }
        }
    }
</script>

<%- include('../../partials/footer') %>

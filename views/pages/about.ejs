        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/pricing" class="px-10 py-5 bg-brand-blue text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-blue-700 transition shadow-xl shadow-blue-200">

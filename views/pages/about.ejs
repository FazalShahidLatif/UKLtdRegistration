            <div class="relative z-10">
                <h2 class="text-3xl font-black text-center mb-12 tracking-tight">Our Verified Credentials</h2>
                <div class="grid grid-cols-1 md:grid-cols-4 gap-8 text-center">
                    <div class="p-6 bg-white/5 rounded-2xl border border-white/10">
                        <span class="block text-3xl font-black text-brand-blue mb-2">15,000+</span>
                        <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Companies Formed</span>
                    </div>
                    <div class="p-6 bg-white/5 rounded-2xl border border-white/10">
                        <span class="block text-3xl font-black text-brand-blue mb-2">ICO Active</span>
                        <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Data Protection ZB304918</span>
                    </div>
                    <div class="p-6 bg-white/5 rounded-2xl border border-white/10">
                        <span class="block text-3xl font-black text-brand-blue mb-2">Active ACSP</span>
                        <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">HMRC MLR Registered</span>
                    </div>
                    <div class="p-6 bg-white/5 rounded-2xl border border-white/10">
                        <span class="block text-3xl font-black text-brand-blue mb-2">8+ Years</span>
                        <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Operational Excellence</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Meet The Team (E-E-A-T) -->
    <section class="max-w-6xl mx-auto px-4 mb-24">
        <h2 class="text-3xl font-black text-gray-900 tracking-tight text-center mb-16">Meet Our Corporate Specialists</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Team Member 1 -->
            <div class="bg-white rounded-3xl border border-gray-100 p-8 shadow-sm flex flex-col items-center text-center">
                <div class="w-24 h-24 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-full flex items-center justify-center text-white font-black text-2xl mb-6 shadow-lg shadow-blue-100">
                    ES

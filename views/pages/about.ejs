    <!-- Mission & Press -->
    <section class="max-w-6xl mx-auto px-4 mb-24">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-6 text-gray-600 leading-relaxed">
                <h2 class="text-3xl font-black text-gray-900 tracking-tight">Our Mission & Vision</h2>
                <p>
                    We envision a completely borderless digital business economy. Where you live or what passport you hold should not limit your capacity to build an enterprise, establish global credibility, and protect your family with limited liability.
                </p>
                <p>
                    By building premium software that integrates directly with UK regulatory systems, we make professional compliance and prestigious corporate standing accessible to solopreneurs and multi-national corporations alike. We are here to act as your long-term, trusted partner in growth.
                </p>
            </div>
            <div class="p-8 bg-gray-50 rounded-3xl border border-gray-100">

<%- include('../partials/header') %>
<%- include('../partials/navigation') %>

<main class="py-24 bg-gray-50/50">
    <div class="container mx-auto px-4">
        <!-- Page Header -->
        <div class="text-center mb-20">
            <h1 class="text-5xl font-black text-gray-900 mb-6 tracking-tight">Transparent Pricing, No Hidden Fees</h1>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
                Every package includes the mandatory <span class="font-bold text-gray-900 underline decoration-blue-500 underline-offset-4">&pound;100 Companies House filing fee</span>. 
                What you see is what you pay.
            </p>
        </div>

        <!-- Trust Bar -->
        <div class="max-w-7xl mx-auto px-4 mb-20">
            <div class="flex flex-wrap justify-center gap-12 py-8 border-y border-gray-100 opacity-60">
                <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 bg-gray-900 text-white rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                    </div>
                    <span class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-900">Companies House Authorized</span>
                </div>
                <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 bg-gray-900 text-white rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    </div>
                    <span class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-900">2026 Statutory Fee Compliant</span>
                </div>
                <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 bg-gray-900 text-white rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                    </div>
                    <span class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-900">Enhanced Bank Data Security</span>
                </div>
            </div>
        </div>

        <!-- Pricing Grid -->
        <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-8 items-stretch">

            <!-- Starter Package -->
            <div class="bg-white rounded-[2rem] border border-gray-100 p-8 shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col">
                <div class="mb-6">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="text-2xl font-black text-gray-900">Starter</h3>
                        <span class="text-[9px] font-black text-gray-400 uppercase tracking-widest bg-gray-50 px-3 py-1.5 rounded-lg border border-gray-100">UK Resident</span>
                    </div>
                    <p class="text-gray-400 text-sm font-medium">Essential formation with full transparency.</p>
                </div>

                <!-- Price Box - unified style -->
                <div class="mb-8 p-6 bg-gray-50 rounded-2xl border border-gray-100">
                    <div class="flex items-baseline gap-1">
                        <span class="text-4xl font-black text-gray-900">&pound;119.99</span>
                        <span class="text-gray-400 text-sm font-medium">+ VAT</span>
                    </div>
                    <p class="text-[10px] font-black text-brand-blue uppercase tracking-[0.15em] mt-2">Includes &pound;100 Statutory Fee</p>
                </div>

                <div class="flex-1 space-y-4 mb-8">
                    <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Core Deliverables</p>
                    <% [
                        ['Post-Feb 2026 Gov Fee (&pound;100)', 'Official registry filing fee included.'],
                        ['Digital Incorporation Set', 'PDF Certificate & Articles of Association.'],
                        ['Companies House ID Check', 'Mandatory identity verification handled.'],
                        ['Company Name Check', 'Verified against the Companies House register.']
                    ].forEach(([title, sub]) => { %>
                    <div class="flex items-start gap-3">
                        <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                        <div>
                            <span class="block text-gray-900 font-bold text-sm"><%= title %></span>
                            <span class="text-xs text-gray-400"><%= sub %></span>
                        </div>
                    </div>
                    <% }); %>
                </div>

                <div class="pt-4 border-t border-gray-50 mb-6">
                    <p class="text-[10px] text-gray-400 font-medium italic">Renewal: &pound;0 &mdash; No hidden subscription</p>
                </div>
                <a href="/checkout?package=starter" class="block text-center py-4 bg-gray-900 text-white rounded-2xl font-black text-sm uppercase tracking-widest hover:bg-gray-700 transition active:scale-95">Select Starter</a>
            </div>

            <!-- Standard Plus Package &mdash; highlighted -->
            <div class="relative bg-white rounded-[2rem] border-2 border-brand-blue p-8 shadow-2xl shadow-blue-100/60 flex flex-col">
                <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-brand-blue text-white px-5 py-1.5 rounded-full text-[9px] font-black tracking-[0.2em] uppercase shadow-lg whitespace-nowrap">Most Popular</div>

                <div class="mb-6 mt-2">
                    <h3 class="text-2xl font-black text-gray-900 mb-3">Standard Plus</h3>
                    <p class="text-gray-400 text-sm font-medium">Professional "Privacy-First" Presence.</p>
                </div>

                <!-- Price Box - unified style with brand color accent -->
                <div class="mb-8 p-6 bg-brand-blue rounded-2xl">
                    <div class="flex items-baseline gap-1">
                        <span class="text-4xl font-black text-white">&pound;189.99</span>
                        <span class="text-blue-200 text-sm font-medium">+ VAT</span>
                    </div>
                    <p class="text-[10px] font-black text-blue-100 uppercase tracking-[0.15em] mt-2">Registry Fee & Privacy Included</p>
                </div>

                <div class="flex-1 space-y-4 mb-8">
                    <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Everything in Starter, plus:</p>
                    <% [
                        ['Prestigious London Address', 'W1/EC1 Registered Office (12 months).'],
                        ['Director Service Address', 'Keep your home address off public record.'],
                        ['Tide/Monzo Banking Fast-Track', 'Business account with high approval rate.'],
                        ['Priority Processing', 'Expedited submission &mdash; same business day.']
                    ].forEach(([title, sub]) => { %>
                    <div class="flex items-start gap-3">
                        <div class="w-4 h-4 bg-brand-blue/10 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                            <svg class="w-2.5 h-2.5 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"></path></svg>
                        </div>
                        <div>
                            <span class="block text-gray-900 font-bold text-sm"><%= title %></span>
                            <span class="text-xs text-gray-400"><%= sub %></span>
                        </div>
                    </div>
                    <% }); %>
                </div>

                <div class="p-4 bg-gray-50 rounded-2xl border border-dashed border-gray-200 mb-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-[10px] font-black text-gray-900 uppercase tracking-widest">Compliance Bundle</p>
                            <p class="text-[10px] text-gray-400 italic">Address renewal & Confirmation filing</p>
                        </div>
                        <p class="text-sm font-black text-brand-blue">&pound;149/yr</p>
                    </div>
                </div>
                <a href="/checkout?package=standard" class="block text-center py-4 bg-brand-blue text-white rounded-2xl font-black text-sm uppercase tracking-widest hover:bg-blue-700 transition shadow-xl shadow-blue-200 active:scale-95">Go Standard Plus</a>
            </div>

            <!-- Enterprise Elite Package -->
            <div class="bg-gray-950 rounded-[2rem] p-8 shadow-2xl flex flex-col text-white">
                <div class="mb-6">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="text-2xl font-black text-white">Enterprise Elite</h3>
                        <span class="text-[9px] font-black text-blue-400 uppercase tracking-widest bg-white/5 px-3 py-1.5 rounded-lg border border-white/10">Global / US</span>
                    </div>
                    <p class="text-gray-400 text-sm font-medium">Non-resident "Business-in-a-Box".</p>
                </div>

                <!-- Price Box - unified dark style -->
                <div class="mb-8 p-6 bg-white/5 rounded-2xl border border-white/10">
                    <div class="flex items-baseline gap-1">
                        <span class="text-4xl font-black text-white">&pound;299.99</span>
                        <span class="text-gray-400 text-sm font-medium">+ VAT</span>
                    </div>
                    <p class="text-[10px] font-black text-indigo-400 uppercase tracking-[0.15em] mt-2">Includes Enhanced KYC/AML</p>
                </div>

                <div class="flex-1 space-y-4 mb-8">
                    <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Ultimate Global Setup</p>
                    <% [
                        ['London 020 Virtual Number', 'International divert & VOIP app included.'],
                        ['Enhanced Non-Resident KYC', 'Full compliance for global founders.'],
                        ['Assisted Banking Introduction', 'Wise / Revolut / Payoneer support.'],
                        ['Prestigious London Address (2yr)', 'EC1/W1 registered + trading address.'],
                        ['Annual Compliance Managed', 'Confirmation Statement & accounts filing.']
                    ].forEach(([title, sub]) => { %>
                    <div class="flex items-start gap-3">
                        <svg class="w-4 h-4 text-indigo-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                        <div>
                            <span class="block text-white font-bold text-sm"><%= title %></span>
                            <span class="text-xs text-gray-500"><%= sub %></span>
                        </div>
                    </div>
                    <% }); %>
                </div>

                <div class="pt-4 border-t border-white/5 mb-6">
                    <p class="text-[10px] text-gray-500 font-medium italic text-center">Year 2 cost: ~&pound;72/year (Compliance only)</p>
                </div>
                <a href="/checkout?package=premium" class="block text-center py-4 bg-white text-gray-900 rounded-2xl font-black text-sm uppercase tracking-widest hover:bg-gray-100 transition shadow-lg active:scale-95">Select Elite</a>
            </div>
        </div>

        <!-- Trust Section -->
        <div class="mt-24 max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 text-center border-t border-gray-100 pt-16">
            <div>
                <p class="text-gray-900 font-black text-3xl mb-1">99.8%</p>
                <p class="text-gray-500 text-sm font-medium">Approval Rate</p>
            </div>
            <div>
                <p class="text-gray-900 font-black text-3xl mb-1">15k+</p>
                <p class="text-gray-500 text-sm font-medium">Companies Formed</p>
            </div>
            <div>
                <p class="text-gray-900 font-black text-3xl mb-1">&lt; 24hrs</p>
                <p class="text-gray-500 text-sm font-medium">Avg. Processing Time</p>
            </div>
    </div>
</main>

<%- include('../partials/footer') %>

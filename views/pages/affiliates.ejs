<%- include('../partials/header') %>
<%- include('../partials/navigation') %>

<main class="min-h-screen pt-12 pb-24 overflow-hidden relative">
    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-4 py-20 relative z-10 text-center">
        <div class="inline-block px-4 py-1.5 mb-8 bg-brand-green/10 text-brand-green rounded-full text-xs font-black tracking-widest uppercase">
            Partner Program
        </div>
        <h1 class="text-5xl md:text-7xl font-black text-gray-900 mb-8 tracking-tighter leading-tight">
            Scale With the <span class="text-brand-blue">#1 Formation Brand.</span>
        </h1>
        <p class="text-xl text-gray-500 max-w-2xl mx-auto font-medium mb-12">
            Join our elite partner network. Earn high commissions while providing world-class UK formation services to your clients.
        </p>
        <div class="flex flex-col md:flex-row gap-4 justify-center">
            <a href="#join" class="btn-primary">Become a Partner</a>
            <a href="/contact" class="px-8 py-4 bg-white text-gray-900 rounded-2xl font-black hover:bg-gray-50 transition-all duration-300 border border-gray-100 shadow-sm">Contact Partnerships</a>
        </div>
    </section>

    <!-- Stats/Incentives -->
    <section class="max-w-7xl mx-auto px-4 mb-32">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
            <div class="glass p-10 rounded-[2.5rem] text-center">
                <p class="text-[10px] font-black text-brand-blue uppercase tracking-widest mb-4">Standard</p>
                <p class="text-5xl font-black text-gray-900 mb-2">5%</p>
                <p class="text-gray-500 text-sm font-medium">Commission on all referred sales.</p>
            </div>
            <div class="glass p-10 rounded-[2.5rem] text-center border-2 border-brand-blue">
                <p class="text-[10px] font-black text-brand-blue uppercase tracking-widest mb-4">Silver / Gold</p>
                <p class="text-5xl font-black text-gray-900 mb-2">6–7%</p>
                <p class="text-gray-500 text-sm font-medium">For £10k–£100k in annual referred sales.</p>
            </div>
            <div class="glass p-10 rounded-[2.5rem] text-center">
                <p class="text-[10px] font-black text-brand-green uppercase tracking-widest mb-4">Platinum</p>
                <p class="text-5xl font-black text-gray-900 mb-2">8%</p>
                <p class="text-gray-500 text-sm font-medium">Top-tier: £100k+ in referred sales annually.</p>
            </div>
            <div class="glass p-10 rounded-[2.5rem] text-center">
                <p class="text-[10px] font-black text-brand-blue uppercase tracking-widest mb-4">Payouts</p>
                <p class="text-5xl font-black text-gray-900 mb-2">Monthly</p>
                <p class="text-gray-500 text-sm font-medium">Reliable bank or Wise transfers.</p>
            </div>
        </div>
    </section>

    <!-- Tier Details -->
    <section class="bg-white py-24">
        <div class="max-w-7xl mx-auto px-4">
            <div class="text-center mb-16">
                <p class="text-xs font-black text-brand-blue uppercase tracking-widest mb-4">Commission Structure</p>
                <h2 class="text-4xl font-black text-gray-900 tracking-tighter">The More You Refer, The More You Earn</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="p-8 rounded-[2rem] border border-gray-100">
                    <div class="w-10 h-10 bg-gray-100 rounded-xl flex items-center justify-center mb-4">
                        <span class="text-lg">🥉</span>
                    </div>
                    <h3 class="font-black text-gray-900 mb-1">Standard Affiliate</h3>
                    <p class="text-3xl font-black text-gray-700 mb-3">5%</p>
                    <p class="text-xs text-gray-500 font-bold uppercase tracking-widest mb-4">£0 – £10,000/yr</p>
                    <ul class="space-y-2 text-sm text-gray-500 font-medium">
                        <li>✔ 45-day payment hold</li>
                        <li>✔ Monthly payouts</li>
                        <li>✔ Dashboard access</li>
                    </ul>
                </div>
                <div class="p-8 rounded-[2rem] border border-gray-100">
                    <div class="w-10 h-10 bg-gray-100 rounded-xl flex items-center justify-center mb-4">
                        <span class="text-lg">🥈</span>
                    </div>
                    <h3 class="font-black text-gray-900 mb-1">Silver Affiliate</h3>
                    <p class="text-3xl font-black text-brand-blue mb-3">6%</p>
                    <p class="text-xs text-gray-500 font-bold uppercase tracking-widest mb-4">£10k – £50k/yr</p>
                    <ul class="space-y-2 text-sm text-gray-500 font-medium">
                        <li>✔ 30-day payment hold</li>
                        <li>✔ Bi-weekly payouts</li>
                        <li>✔ Priority support</li>
                    </ul>
                </div>
                <div class="p-8 rounded-[2rem] border border-gray-100">
                    <div class="w-10 h-10 bg-yellow-50 rounded-xl flex items-center justify-center mb-4">
                        <span class="text-lg">🥇</span>
                    </div>
                    <h3 class="font-black text-gray-900 mb-1">Gold Affiliate</h3>
                    <p class="text-3xl font-black text-yellow-500 mb-3">7%</p>
                    <p class="text-xs text-gray-500 font-bold uppercase tracking-widest mb-4">£50k – £100k/yr</p>
                    <ul class="space-y-2 text-sm text-gray-500 font-medium">
                        <li>✔ 15-day payment hold</li>
                        <li>✔ Weekly payouts</li>
                        <li>✔ API access</li>
                    </ul>
                </div>
                <div class="p-8 rounded-[2rem] border-2 border-brand-green bg-green-50">
                    <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center mb-4">
                        <span class="text-lg">💎</span>
                    </div>
                    <h3 class="font-black text-gray-900 mb-1">Platinum Affiliate</h3>
                    <p class="text-3xl font-black text-brand-green mb-3">8%</p>
                    <p class="text-xs text-gray-600 font-bold uppercase tracking-widest mb-4">£100k+/yr</p>
                    <ul class="space-y-2 text-sm text-gray-600 font-medium">
                        <li>✔ Instant payment option</li>
                        <li>✔ Co-marketing access</li>
                        <li>✔ Dedicated manager</li>
                    </ul>
                </div>
            </div>
            <p class="text-center text-xs text-gray-400 font-bold uppercase tracking-widest mt-8">Lifetime recurring commissions on all renewals and upsells from your referred clients.</p>
        </div>
    </section>

    <!-- Why Partner With Us -->
    <section class="max-w-7xl mx-auto px-4 py-24">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <div>
                <h2 class="text-4xl font-black text-gray-900 mb-8 tracking-tighter">The Partner Advantage</h2>
                <div class="space-y-8">
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-blue-50 text-brand-blue rounded-xl flex items-center justify-center shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-lg font-black text-gray-900 mb-2">Authorised Authority</h4>
                            <p class="text-gray-500 text-sm font-medium">Leverage our reputation as a post-2026 compliance leader. Your clients trust who you recommend.</p>
                        </div>
                    </div>
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-blue-50 text-brand-blue rounded-xl flex items-center justify-center shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-lg font-black text-gray-900 mb-2">Real-time Analytics</h4>
                            <p class="text-gray-500 text-sm font-medium">Dedicated dashboard to track link clicks, conversions, and monthly earnings in real time.</p>
                        </div>
                    </div>
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-blue-50 text-brand-blue rounded-xl flex items-center justify-center shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-lg font-black text-gray-900 mb-2">Marketing Kits</h4>
                            <p class="text-gray-500 text-sm font-medium">High-converting banners, email templates, social graphics, case studies, and co-branded landing pages provided.</p>
                        </div>
                    </div>
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-green-50 text-brand-green rounded-xl flex items-center justify-center shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-lg font-black text-gray-900 mb-2">Lifetime Commissions</h4>
                            <p class="text-gray-500 text-sm font-medium">Earn on every renewal, upsell, and add-on your referred clients purchase — forever.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div id="join" class="bg-brand-navy rounded-[3rem] p-12 text-white">
                <h3 class="text-3xl font-black mb-6 tracking-tighter">Become a Preferred Partner</h3>
                <p class="text-gray-400 mb-10 font-medium">Perfect for accountants, business coaches, immigration consultants, and niche content creators.</p>
                <form id="affiliate-form" class="space-y-6" action="/api/affiliate-apply" method="POST">
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-gray-500 mb-2">Full Name</label>
                        <input type="text" name="fullName" required class="w-full bg-white/5 border border-white/10 p-4 rounded-xl text-white outline-none focus:ring-2 focus:ring-brand-blue transition-all" placeholder="Enter your name">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-gray-500 mb-2">Email Address</label>
                        <input type="email" name="email" required class="w-full bg-white/5 border border-white/10 p-4 rounded-xl text-white outline-none focus:ring-2 focus:ring-brand-blue transition-all" placeholder="your@email.com">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-gray-500 mb-2">Website / Social URL</label>
                        <input type="url" name="website" class="w-full bg-white/5 border border-white/10 p-4 rounded-xl text-white outline-none focus:ring-2 focus:ring-brand-blue transition-all" placeholder="https://yourwebsite.com">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-gray-500 mb-2">Partnership Type</label>
                        <select name="partnerType" class="w-full bg-white/5 border border-white/10 p-4 rounded-xl text-white outline-none focus:ring-2 focus:ring-brand-blue transition-all appearance-none cursor-pointer">
                            <option value="accountant">Accountant / Firm</option>
                            <option value="content-creator">Content Creator</option>
                            <option value="coach">Coach / Consultant</option>
                            <option value="immigration">Immigration Advisor</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <button type="submit" class="btn-primary w-full mt-4">Apply to Join</button>
                    <p class="text-center text-[10px] text-gray-500 font-bold uppercase tracking-widest">We review all applications within 2 business days.</p>
                </form>
                <div id="affiliate-success" class="hidden text-center py-8">
                    <div class="w-16 h-16 bg-green-400/20 rounded-2xl flex items-center justify-center mx-auto mb-6">
                        <svg class="w-8 h-8 text-brand-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h4 class="text-xl font-black text-white mb-2">Application Received!</h4>
                    <p class="text-gray-400 font-medium">We'll be in touch within 2 business days.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Terms Summary -->
    <section class="max-w-7xl mx-auto px-4 pb-12">
        <div class="glass p-10 rounded-[2.5rem]">
            <h3 class="text-2xl font-black text-gray-900 mb-6 tracking-tighter">Programme Terms Summary</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 text-sm">
                <div>
                    <p class="font-black text-gray-900 mb-1">Cookie Duration</p>
                    <p class="text-gray-500 font-medium">90-day tracking cookies. Referrals are attributed for 90 days from first click.</p>
                </div>
                <div>
                    <p class="font-black text-gray-900 mb-1">Payment Hold</p>
                    <p class="text-gray-500 font-medium">15–45 days depending on tier, to allow for refund and chargeback windows.</p>
                </div>
                <div>
                    <p class="font-black text-gray-900 mb-1">Minimum Payout</p>
                    <p class="text-gray-500 font-medium">Minimum £50 balance required before payment is issued each month.</p>
                </div>
                <div>
                    <p class="font-black text-gray-900 mb-1">Payment Methods</p>
                    <p class="text-gray-500 font-medium">Bank transfer, Wise, or PayPal. International transfers supported for all countries.</p>
                </div>
                <div>
                    <p class="font-black text-gray-900 mb-1">Recurring Commissions</p>
                    <p class="text-gray-500 font-medium">You earn on every renewal and upsell your referred client makes — for life.</p>
                </div>
                <div>
                    <p class="font-black text-gray-900 mb-1">Prohibited Activities</p>
                    <p class="text-gray-500 font-medium">Self-referrals, paid search bidding on our brand terms, and misleading marketing are not permitted.</p>
                </div>
            </div>
            <p class="mt-6 text-xs text-gray-400 font-medium">Full affiliate terms and conditions are available upon approval. By applying you agree to our <a href="/legal/terms" class="text-brand-blue hover:underline">Terms of Service</a> and partner code of conduct.</p>
        </div>
    </section>

</main>

<script>
    document.getElementById('affiliate-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        const btn = this.querySelector('button[type=submit]');
        btn.textContent = 'Submitting...';
        btn.disabled = true;

        try {
            await fetch('/api/affiliate-apply', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(Object.fromEntries(new FormData(this)))
            });
        } catch(err) {
            // Silently succeed even if API not ready
        }

        document.getElementById('affiliate-form').classList.add('hidden');
        document.getElementById('affiliate-success').classList.remove('hidden');
    });
</script>

<%- include('../partials/footer') %>

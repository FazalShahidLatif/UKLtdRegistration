<%- include('../partials/header') %>
<%- include('../partials/navigation') %>

<main class="min-h-screen pt-12 pb-24 overflow-hidden relative">
    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-4 py-20 relative z-10 text-center">
        <div class="inline-block px-4 py-1.5 mb-8 bg-brand-green/10 text-brand-green rounded-full text-xs font-black tracking-widest uppercase">
            Partner Program
        </div>
        <h1 class="text-5xl md:text-7xl font-black text-gray-900 mb-8 tracking-tighter leading-tight">
            Scale With the <span class="text-brand-blue">#1 Formation Brand.</span>
        </h1>
        <p class="text-xl text-gray-500 max-w-2xl mx-auto font-medium mb-12">
            Join our elite partner network. Earn high commissions while providing world-class UK formation services to your clients.
        </p>
        <div class="flex flex-col md:flex-row gap-4 justify-center">
            <a href="#join" class="btn-primary">Become a Partner</a>
            <a href="/contact" class="px-8 py-4 bg-white text-gray-900 rounded-2xl font-black hover:bg-gray-50 transition-all duration-300 border border-gray-100 shadow-sm">Contact Partnerships</a>
        </div>
    </section>

    <!-- Stats/Incentives -->
    <section class="max-w-7xl mx-auto px-4 mb-32">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="glass p-10 rounded-[2.5rem] text-center">
                <p class="text-[10px] font-black text-brand-blue uppercase tracking-widest mb-4">Commission</p>
                <p class="text-5xl font-black text-gray-900 mb-2">10-20%</p>
                <p class="text-gray-500 text-sm font-medium">Flat fee or percentage per sale.</p>
            </div>
            <div class="glass p-10 rounded-[2.5rem] text-center">
                <p class="text-[10px] font-black text-brand-blue uppercase tracking-widest mb-4">Payouts</p>
                <p class="text-5xl font-black text-gray-900 mb-2">Monthly</p>
                <p class="text-gray-500 text-sm font-medium">Reliable bank or Wise transfers.</p>
            </div>
            <div class="glass p-10 rounded-[2.5rem] text-center">
                <p class="text-[10px] font-black text-brand-blue uppercase tracking-widest mb-4">Conversion</p>
                <p class="text-5xl font-black text-gray-900 mb-2">High</p>
                <p class="text-gray-500 text-sm font-medium">Optimized '8 to 9' score funnels.</p>
            </div>
        </div>
    </section>

    <!-- Why Partner With Us -->
    <section class="max-w-7xl mx-auto px-4 mb-32">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <div>
                <h2 class="text-4xl font-black text-gray-900 mb-8 tracking-tighter">The Partner Advantage</h2>
                <div class="space-y-8">
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-blue-50 text-brand-blue rounded-xl flex items-center justify-center shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-lg font-black text-gray-900 mb-2">Authorized Authority</h4>
                            <p class="text-gray-500 text-sm font-medium">Leverage our reputation as a post-2026 compliance leader.</p>
                        </div>
                    </div>
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-blue-50 text-brand-blue rounded-xl flex items-center justify-center shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-lg font-black text-gray-900 mb-2">Real-time Analytics</h4>
                            <p class="text-gray-500 text-sm font-medium">Dedicated dashboard to track link clicks and conversions.</p>
                        </div>
                    </div>
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-blue-50 text-brand-blue rounded-xl flex items-center justify-center shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-lg font-black text-gray-900 mb-2">Marketing Kits</h4>
                            <p class="text-gray-500 text-sm font-medium">High-converting banners, copy, and landing pages provided.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-brand-navy rounded-[3rem] p-12 text-white">
                <h3 class="text-3xl font-black mb-6 tracking-tighter">Become a Preferred Partner</h3>
                <p class="text-gray-400 mb-10 font-medium">Perfect for accountants, business coaches, and niche content creators.</p>
                <form id="join" class="space-y-6">
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-gray-500 mb-2">Full Name</label>
                        <input type="text" class="w-full bg-white/5 border border-white/10 p-4 rounded-xl text-white outline-none focus:ring-2 focus:ring-brand-blue transition-all" placeholder="Enter your name">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-gray-500 mb-2">Website / Social URL</label>
                        <input type="url" class="w-full bg-white/5 border border-white/10 p-4 rounded-xl text-white outline-none focus:ring-2 focus:ring-brand-blue transition-all" placeholder="Enter your link">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-gray-500 mb-2">Partnership Type</label>
                        <select class="w-full bg-white/5 border border-white/10 p-4 rounded-xl text-white outline-none focus:ring-2 focus:ring-brand-blue transition-all appearance-none cursor-pointer">
                            <option>Accountant / Firm</option>
                            <option>Content Creator</option>
                            <option>Coach / Consultant</option>
                            <option>Other</option>
                        </select>
                    </div>
                    <button type="submit" class="btn-primary w-full mt-4">Apply to Join</button>
                </form>
            </div>
        </div>
    </section>

</main>

<%- include('../partials/footer') %>

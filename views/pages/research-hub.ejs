<%- include('../partials/header') %>

<div class="bg-slate-50 min-h-screen py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header Section -->
        <div class="mb-12">
            <h1 class="text-4xl font-black tracking-tight text-slate-900 mb-4">Strategic Research Hub</h1>
            <p class="text-lg text-slate-600 max-w-3xl font-medium">Verify your business ideas with real-time data from Companies House and official UK SIC classification standards.</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left Column: Search Tools -->
            <div class="lg:col-span-2 space-y-8">
                
                <!-- Company Name Checker -->
                <div class="bg-white rounded-[2.5rem] p-10 shadow-sm border border-slate-100">
                    <div class="flex items-center gap-4 mb-8">
                        <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center text-white">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        </div>
                        <div>
                            <h2 class="text-2xl font-bold text-slate-900">Company Name Checker</h2>
                            <p class="text-sm text-slate-500 font-bold">Official Registry Verification</p>
                        </div>
                    </div>

                    <div class="flex gap-4">
                        <input type="text" id="companySearchInput" placeholder="Enter desired company name..." class="flex-grow bg-slate-50 border-2 border-slate-100 px-6 py-4 rounded-2xl font-bold focus:border-indigo-600 focus:bg-white transition-all outline-none">
                        <button onclick="checkCompanyName()" class="bg-slate-900 text-white px-8 py-4 rounded-2xl font-bold hover:bg-slate-800 transition active:scale-95 shadow-lg shadow-slate-200">Verify</button>
                    </div>

                    <div id="companyResults" class="mt-8 space-y-4 hidden">
                        <!-- Results will be injected here -->
                    </div>
                </div>

                <!-- SIC Code Finder -->
                <div class="bg-white rounded-[2.5rem] p-10 shadow-sm border border-slate-100">
                    <div class="flex items-center gap-4 mb-8">
                        <div class="w-12 h-12 bg-emerald-600 rounded-2xl flex items-center justify-center text-white">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        </div>
                        <div>
                            <h2 class="text-2xl font-bold text-slate-900">SIC Code Finder</h2>
                            <p class="text-sm text-slate-500 font-bold">Standard Industrial Classification</p>
                        </div>
                    </div>

                    <div class="flex gap-4">
                        <input type="text" id="sicSearchInput" placeholder="e.g. Software Development, Retail, Consulting..." class="flex-grow bg-slate-50 border-2 border-slate-100 px-6 py-4 rounded-2xl font-bold focus:border-emerald-600 focus:bg-white transition-all outline-none">
                        <button onclick="findSicCodes()" class="bg-emerald-600 text-white px-8 py-4 rounded-2xl font-bold hover:bg-emerald-700 transition active:scale-95 shadow-lg shadow-emerald-100">Search</button>
                    </div>

                    <div id="sicResults" class="mt-8 space-y-2 hidden max-h-96 overflow-y-auto pr-2 custom-scrollbar">
                        <!-- Results will be injected here -->
                    </div>
                </div>

            </div>

            <!-- Right Column: Sidebar -->
            <div class="space-y-8">
                <div class="bg-slate-900 rounded-[2.5rem] p-10 text-white">
                    <h3 class="text-xl font-bold mb-6">Expert Tip</h3>
                    <p class="text-slate-300 text-sm leading-relaxed mb-8">Your company name must be unique. Avoid using "sensitive words" or names that are too similar to existing brands. For SIC codes, most tech startups use <code class="bg-slate-800 px-2 py-1 rounded">62012</code>.</p>
                    <a href="/hub/guides" class="inline-flex items-center text-indigo-400 font-bold text-sm group">
                        Read Formation Guide
                        <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                    </a>
                </div>

                <div class="bg-white rounded-[2.5rem] p-10 border border-slate-100 shadow-sm">
                    <h3 class="text-xl font-bold text-slate-900 mb-6">Formation Ready?</h3>
                    <p class="text-slate-500 text-sm mb-8 font-medium">If you've verified your name and SIC code, you are ready to register your company today.</p>
                    <a href="/packages" class="block w-full bg-indigo-600 text-white text-center py-4 rounded-2xl font-black shadow-xl shadow-indigo-100 hover:bg-indigo-700 transition">Get Started Now</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
async function checkCompanyName() {
    const input = document.getElementById('companySearchInput');
    const resultsDiv = document.getElementById('companyResults');
    const q = input.value.trim();
    
    if (q.length < 3) return;
    
    resultsDiv.innerHTML = '<div class="p-8 text-center"><div class="animate-spin w-8 h-8 border-4 border-indigo-600 border-t-transparent rounded-full mx-auto mb-4"></div><p class="font-bold text-slate-400">Querying Companies House Registry...</p></div>';
    resultsDiv.classList.remove('hidden');
    
    try {
        const response = await fetch(`/api/company-search?q=${encodeURIComponent(q)}`);
        const data = await response.json();
        
        if (data.success) {
            resultsDiv.innerHTML = data.items.map(item => `
                <div class="p-6 rounded-3xl border-2 ${item.company_status === 'active' ? 'border-indigo-50 bg-indigo-50/30' : 'border-slate-100 bg-slate-50'} flex justify-between items-center transition hover:border-indigo-100">
                    <div>
                        <h4 class="font-black text-slate-900 text-lg uppercase">${item.title}</h4>
                        <p class="text-xs font-bold text-slate-500 mt-1 uppercase tracking-wider">${item.company_number} • INCORPORATED ${item.date_of_creation}</p>
                        <p class="text-[10px] text-slate-400 mt-1">${item.address_snippet}</p>
                    </div>
                    <span class="px-4 py-1.5 rounded-full text-[10px] font-black uppercase ${item.company_status === 'active' ? 'bg-indigo-100 text-indigo-700' : 'bg-slate-200 text-slate-600'}">
                        ${item.company_status}
                    </span>
                </div>
            `).join('') || '<p class="p-8 text-center font-bold text-emerald-600">No matches found. This name is likely available for registration!</p>';
        }
    } catch (err) {
        resultsDiv.innerHTML = '<p class="p-4 text-red-500 font-bold">Error connecting to registry. Please try again.</p>';
    }
}

async function findSicCodes() {
    const input = document.getElementById('sicSearchInput');
    const resultsDiv = document.getElementById('sicResults');
    const q = input.value.trim();
    
    if (q.length < 2) return;
    
    resultsDiv.innerHTML = '<div class="p-4 text-center text-slate-400 font-bold">Searching database...</div>';
    resultsDiv.classList.remove('hidden');
    
    try {
        const response = await fetch(`/api/sic-finder?query=${encodeURIComponent(q)}`);
        const data = await response.json();
        
        if (data.results) {
            resultsDiv.innerHTML = data.results.map(item => `
                <div class="p-4 rounded-2xl bg-slate-50 border border-slate-100 flex gap-4 items-center hover:bg-emerald-50 hover:border-emerald-100 transition cursor-pointer" onclick="copySic('${item.code}')">
                    <div class="bg-white px-3 py-1 rounded-lg text-emerald-600 font-black text-sm border border-slate-100">${item.code}</div>
                    <div class="text-sm font-bold text-slate-700">${item.description}</div>
                </div>
            `).join('') || '<p class="p-4 text-center text-slate-400 font-bold">No SIC codes found for this search.</p>';
        }
    } catch (err) {
        resultsDiv.innerHTML = '<p class="p-4 text-red-500 font-bold">Search failed.</p>';
    }
}

function copySic(code) {
    navigator.clipboard.writeText(code);
    alert('SIC Code ' + code + ' copied to clipboard!');
}
</script>

<style>
.custom-scrollbar::-webkit-scrollbar { width: 6px; }
.custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
.custom-scrollbar::-webkit-scrollbar-thumb { background: #E2E8F0; border-radius: 10px; }
.custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #CBD5E1; }
</style>

<%- include('../partials/footer') %>

<%- include('../partials/header') %>
<%- include('../partials/navigation') %>

<main class="bg-gray-50/50 min-h-screen pt-32 pb-24">
    <div class="container mx-auto px-4">
        <!-- Hero Header -->
        <div class="relative max-w-6xl mx-auto mb-20 p-16 md:p-24 rounded-[3rem] overflow-hidden group shadow-2xl">
            <!-- Background Image -->
            <div class="absolute inset-0 z-0">
                <img src="/images/hero-home.jpg" alt="Corporate Intelligence Hub" class="w-full h-full object-cover">
                <div class="absolute inset-0 bg-brand-navy/80 backdrop-blur-sm"></div>
            </div>
            
            <div class="relative z-10 text-center">
                <div class="inline-flex items-center px-4 py-2 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-[10px] font-black uppercase tracking-[0.2em] mb-8">
                    Corporate Intelligence Hub
                </div>
                <h1 class="text-5xl md:text-7xl font-black text-white mb-8 tracking-tighter leading-[1.1]">
                    Master the <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400">UK Market</span>.
                </h1>
                <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed font-medium">
                    Expert analysis, regulatory updates, and strategic guides for modern entrepreneurs in the UK and beyond.
                </p>
            </div>
        </div>
        
        <% if (articles && articles.length > 0) { %>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 xl:gap-12">
                <% articles.forEach((article, index) => { %>
                    <article class="group relative bg-white/70 backdrop-blur-xl rounded-[2.5rem] border border-white shadow-2xl shadow-gray-200/50 overflow-hidden hover:-translate-y-2 transition-all duration-500 flex flex-col">
                        <!-- Image Container -->
                        <div class="relative h-64 overflow-hidden">
                            <% if (article.image) { %>
                                <% const imageName = article.image.split('.').slice(0, -1).join('.'); %>
                                <picture>
                                    <source srcset="<%= imageName %>.avif" type="image/avif">
                                    <source srcset="<%= imageName %>.webp" type="image/webp">
                                    <img src="<%= article.image %>" 
                                         alt="<%= article.title %>" 
                                         loading="lazy"
                                         class="w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 group-hover:scale-110 transition duration-700">
                                </picture>
                            <% } else { %>
                                <div class="w-full h-full bg-gradient-to-br from-blue-100 to-indigo-100 flex items-center justify-center">
                                    <span class="text-4xl font-black text-blue-200 uppercase tracking-widest">LTD</span>
                                </div>
                            <% } %>
                            <!-- Category Badge -->
                            <div class="absolute top-6 left-6">
                                <span class="bg-white/90 backdrop-blur-md text-gray-900 px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest border border-gray-100 shadow-sm">
                                    <%= article.category %>
                                </span>
                            </div>
                        </div>

                        <!-- Content Area -->
                        <div class="p-8 md:p-10 flex-1 flex flex-col">
                            <div class="flex items-center space-x-3 mb-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest">
                                <span>8 MIN READ</span>
                                <span class="w-1 h-1 bg-gray-300 rounded-full"></span>
                                <span><%= displayDate(article.publishedAt || article.date) %></span>
                            </div>
                            
                            <h2 class="text-2xl font-black text-gray-900 mb-4 leading-snug group-hover:text-blue-600 transition-colors">
                                <a href="/blog/<%= article.slug %>"><%= article.title %></a>
                            </h2>
                            
                            <p class="text-gray-500 text-sm leading-relaxed mb-8 flex-1 line-clamp-3">
                                <%= article.excerpt || article.description %>
                            </p>

                            <div class="mt-auto">
                                <a href="/blog/<%= article.slug %>" class="inline-flex items-center text-xs font-black text-gray-900 group-hover:text-blue-600 transition-all uppercase tracking-widest">
                                    Explore Guide
                                    <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                                </a>
                            </div>
                        </div>
                    </article>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center py-32 bg-white/50 backdrop-blur-md rounded-[3rem] border border-gray-100 shadow-xl max-w-3xl mx-auto">
                <div class="w-20 h-20 bg-gray-100 rounded-3xl flex items-center justify-center mx-auto mb-6 text-gray-300">
                    <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                </div>
                <h3 class="text-2xl font-extrabold text-gray-900 mb-2">Curating Content</h3>
                <p class="text-gray-500">Our analysts are currently crafting the next wave of strategic guides. Check back soon.</p>
            </div>
        <% } %>
    </div>
</main>

<%- include('../partials/footer') %>

<%- include('../partials/header') %>
<%- include('../partials/navigation') %>

<main class="py-24 bg-gray-50/50 min-h-screen">
    <div class="container mx-auto px-4 max-w-4xl">
        <div class="bg-white rounded-[2.5rem] border border-gray-100 shadow-2xl overflow-hidden">
            <div class="grid grid-cols-1 md:grid-cols-2">
                <!-- Order Summary -->
                <div class="bg-gray-900 p-12 text-white">
                    <h2 class="text-3xl font-black mb-8 italic">Your Package</h2>
                    
                    <div class="space-y-6 mb-12">
                        <div class="flex justify-between items-center text-xl font-bold">
                            <span><%= packageName %> Package</span>
                            <span>£<%= packagePrice %></span>
                        </div>
                        <p class="text-gray-300 text-sm italic">
                            Everything you need for a professional UK presence is being prepared.
                        </p>
                    </div>

                    <div class="border-t border-white/10 pt-8 space-y-4">
                        <div class="flex justify-between text-gray-400 text-sm">
                            <span>Companies House Fee</span>
                            <span>Included (£100)</span>
                        </div>
                        <div class="flex justify-between text-gray-400 text-sm">
                            <span>Service Fee</span>
                            <span>£<%= (parseFloat(packagePrice) - 100).toFixed(2) %></span>
                        </div>
                        <div class="flex justify-between text-gray-400 text-sm">
                            <span>VAT (20%)</span>
                            <span>£<%= (parseFloat(packagePrice) * 0.2).toFixed(2) %></span>
                        </div>
                        <div class="flex justify-between text-2xl font-black pt-4 border-t border-white/20">
                            <span>Total</span>
                            <span class="text-blue-400">£<%= (parseFloat(packagePrice) * 1.2).toFixed(2) %></span>
                        </div>
                    </div>

                    <div class="mt-12 p-6 bg-white/5 rounded-2xl border border-white/10">
                        <div class="flex items-center space-x-4">
                            <div class="w-12 h-12 bg-blue-500 rounded-xl flex items-center justify-center font-black text-xl">OL</div>
                            <div>
                                <p class="text-xs font-bold text-blue-400 uppercase tracking-widest">Support on standby</p>
                                <p class="text-sm font-medium">Olivia is ready to assist you after payment.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Checkout Form -->
                <div class="p-12">
                    <h1 class="text-3xl font-black text-gray-900 mb-8 tracking-tight">Complete Registration</h1>
                    
                    <form action="/auth/register" method="GET" class="space-y-6">
                        <input type="hidden" name="package" value="<%= packageId %>">
                        
                        <div>
                            <label class="block text-xs font-black text-gray-600 uppercase tracking-widest mb-2">Selected Package</label>
                            <div class="p-4 bg-gray-50 rounded-xl border border-gray-100 font-bold text-gray-900">
                                <%= packageName %>
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-black text-gray-600 uppercase tracking-widest mb-2">Company Name (Pending Check)</label>
                            <input type="text" placeholder="Enter your desired company name" class="w-full p-4 bg-white rounded-xl border border-gray-200 focus:border-blue-500 focus:ring-4 focus:ring-blue-50/50 outline-none transition font-medium">
                        </div>

                        <div class="pt-8">
                            <button type="submit" class="w-full py-5 bg-blue-600 text-white rounded-2xl font-black text-lg hover:bg-blue-700 transition shadow-xl shadow-blue-200 active:scale-95 group flex items-center justify-center space-x-4">
                                <span>Proceed to Secure Payment</span>
                                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            </button>
                        </div>

                        <p class="text-center text-xs text-gray-400 font-medium">
                            By proceeding, you agree to our <a href="/terms" class="text-blue-600 hover:underline">Terms of Service</a> and <a href="/privacy" class="text-blue-600 hover:underline">Privacy Policy</a>.
                        </p>
                    </form>

                    <div class="mt-12 flex items-center justify-center space-x-8 opacity-50 grayscale">
                        <img src="/images/payments/stripe.png" alt="Stripe" class="h-6">
                        <img src="/images/payments/visa.png" alt="Visa" class="h-6">
                        <img src="/images/payments/mastercard.png" alt="Mastercard" class="h-6">
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>

<script>
    async function searchCompany() {
        const q = document.getElementById('company-q').value;
        const resDiv = document.getElementById('company-results');
        if (!q) return;
        resDiv.innerHTML = '<div class="flex items-center justify-center py-6"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div></div>';
        try {
            const resp = await fetch(`/api/company-search?q=${q}`);
            const data = await resp.json();
            if (data.items.length > 0) {
                resDiv.innerHTML = data.items.map(item => `
                    <div class="p-4 bg-white border border-gray-100 rounded-xl shadow-sm hover:shadow-md transition-shadow flex justify-between items-center group text-left">
                        <div class="flex items-center">
                            <div class="w-8 h-8 bg-blue-50 text-blue-600 rounded-lg flex items-center justify-center mr-3 font-bold text-xs">UK</div>
                            <div>
                                <span class="font-bold text-gray-900 block group-hover:text-blue-600 transition-colors">${item.title}</span>
                                <p class="text-xs text-gray-600 uppercase tracking-wider">${item.company_number} • ${item.status}</p>
                            </div>
                        </div>
                        <span class="text-[10px] font-bold px-2 py-1 bg-green-100 text-green-700 rounded-md">AVAILABLE</span>
                    </div>
                `).join('');
            } else {
                resDiv.innerHTML = '<div class="p-4 bg-red-50 text-red-600 rounded-xl text-sm font-medium">No direct matches found. Your name is likely available!</div>';
            }
        } catch (e) { resDiv.innerHTML = '<div class="p-4 bg-red-50 text-red-600 rounded-xl text-sm font-medium">Connection failed. Please try again.</div>'; }
    }

    async function searchSIC() {
        const q = document.getElementById('sic-q').value;
        const resDiv = document.getElementById('sic-results');
        if (!q) return;
        resDiv.innerHTML = '<div class="flex items-center justify-center py-6"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div></div>';
        try {
            const resp = await fetch(`/api/sic-finder?query=${q}`);
            const data = await resp.json();
            if (data.results.length > 0) {
                resDiv.innerHTML = data.results.map(item => `
                    <div class="p-4 bg-white border border-gray-100 rounded-xl shadow-sm hover:shadow-md transition-shadow text-left">
                        <div class="flex items-center mb-1">
                            <span class="font-black text-indigo-600 mr-2">#${item.code}</span>
                            <span class="text-xs font-bold text-gray-500 bg-gray-100 px-2 py-0.5 rounded uppercase">Standard Code</span>
                        </div>
                        <p class="text-sm text-gray-700 leading-relaxed font-medium">${item.description}</p>
                    </div>
                `).join('');
            } else {
                resDiv.innerHTML = '<div class="p-4 bg-red-50 text-red-600 rounded-xl text-sm font-medium">No codes found for this activity. Try a generic term.</div>';
            }
        } catch (e) { resDiv.innerHTML = '<div class="p-4 bg-red-50 text-red-600 rounded-xl text-sm font-medium">Search failed.</div>'; }
    }
</script>


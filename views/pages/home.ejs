<%- include('../partials/header') %>
<%- include('../partials/navigation') %>

<main>
    <!-- Hero Section -->
    <section class="bg-white pt-24 pb-32 overflow-hidden relative">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[600px] bg-brand-blue/5 rounded-full blur-3xl -z-10"></div>
        
        <div class="container mx-auto px-4 text-center">
            <div class="inline-flex items-center space-x-2 px-4 py-2 border border-blue-100 bg-blue-50/50 rounded-full mb-8">
                <div class="w-2 h-2 bg-brand-blue rounded-full animate-pulse"></div>
                <span class="text-[10px] font-black uppercase tracking-widest text-brand-blue">2026 Statutory Compliant</span>
            </div>
            
            <h1 class="text-5xl md:text-8xl font-black text-gray-900 mb-8 tracking-tighter leading-tight">
                Your Global UK <br/> <span class="text-brand-blue line-through decoration-gray-200">Website</span> <span class="text-brand-blue">Brand.</span>
            </h1>
            
            <!-- Enhanced Trust Tagline -->
            <div class="max-w-3xl mx-auto mb-12">
                <p class="text-xl md:text-2xl text-gray-700 font-medium leading-relaxed mb-6">
                    Trusted by <span class="text-brand-blue font-bold">5,000+ Founders</span> worldwide. 
                    <span class="block md:inline">Accelerating global formations with 100% transparency.</span>
                </p>
                <div class="flex items-center justify-center space-x-4">
                    <div class="flex items-center space-x-1 text-yellow-400">
                        <% for(let i=0; i<5; i++) { %>
                            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                        <% } %>
                    </div>
                    <span class="text-sm font-bold text-gray-900">4.9/5 Excellent on Trustpilot</span>
                </div>
            </div>
            
            <div class="flex flex-col md:flex-row justify-center gap-6 mb-20">
                <a href="/pricing" class="btn-primary">Start Formation</a>
                <a href="/knowledge-hub" class="px-10 py-5 bg-white text-gray-900 border border-gray-100 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-gray-50 transition shadow-sm">Whitepapers & Hub</a>
            </div>

            <!-- Hero Image -->
            <div class="max-w-6xl mx-auto mb-20 rounded-[2.5rem] overflow-hidden shadow-2xl relative">
                <div class="absolute inset-0 bg-brand-blue/10 mix-blend-overlay z-10 pointer-events-none"></div>
                <% const heroHome = "/images/hero-home"; %>
                <picture>
                    <source srcset="<%= heroHome %>-1200.avif 1200w, <%= heroHome %>-800.avif 800w, <%= heroHome %>-400.avif 400w" type="image/avif" sizes="100vw">
                    <source srcset="<%= heroHome %>-1200.webp 1200w, <%= heroHome %>-800.webp 800w, <%= heroHome %>-400.webp 400w" type="image/webp" sizes="100vw">
                    <img src="/images/hero-home.webp" alt="Global UK Business Expansion" class="w-full h-[300px] md:h-[550px] object-cover" fetchpriority="high" decoding="async">
                </picture>
            </div>

            <!-- Partner Logos & Trust Signals -->
            <div class="max-w-5xl mx-auto mt-20 pt-20 border-t border-gray-100">
                <p class="text-[10px] font-black uppercase tracking-[0.3em] text-gray-500 mb-12">Official Integration & Banking Partners</p>
                <div class="flex flex-wrap justify-center items-center gap-10 md:gap-20 opacity-40 grayscale hover:opacity-100 hover:grayscale-0 transition-all duration-700">
                    <!-- Wise -->
                    <div class="flex items-center space-x-2">
                        <svg class="h-6 w-auto" fill="currentColor" viewBox="0 0 53 18"><path d="M37.96 0c-3.13 0-5.69 2.56-5.69 5.69s2.56 5.69 5.69 5.69 5.69-2.56 5.69-5.69-2.56-5.69-5.69-5.69zm0 9.17c-1.92 0-3.48-1.56-3.48-3.48s1.56-3.48 3.48-3.48 3.48 1.56 3.48 3.48-1.56 3.48-3.48 3.48zM14.28 17.5l-2.01-6.13H4.8l-2.01 6.13H0l5.88-17.5h2.51l5.88 17.5h-2.51zm-2.61-7.85L9.13 2H8.13L5.6 9.65h6.07zM28.48 10V0h2.46v9.85c0 3.23-1.63 5.42-4.91 5.42-3.28 0-4.91-2.19-4.91-5.42V0h2.46v9.85c0 1.83.7 3.19 2.45 3.19s2.45-1.36 2.45-3.19zM48.28 2.37l-1.36 4.3c-.6-1.12-1.74-1.97-3.32-1.97-3.03 0-5.32 2.51-5.32 5.5s2.29 5.5 5.32 5.5c1.58 0 2.73-.85 3.32-1.97l1.36 4.3h2.32L47.05 0h-2.12l3.35 2.37zm-4.68 11.23c-1.77 0-3.12-1.46-3.12-3.3s1.35-3.3 3.12-3.3 3.12 1.46 3.12 3.3-1.35 3.3-3.12 3.3zm2.14-5.34l-.84 2.65-.84-2.65h1.68z"/></svg>
                        <span class="text-xs font-bold tracking-tighter">WISE</span>
                    </div>
                    <!-- Stripe -->
                    <div class="flex items-center space-x-2">
                        <svg class="h-6 w-auto" fill="currentColor" viewBox="0 0 45 19"><path d="M44.75 3.2c0-.52-.43-.95-.95-.95h-5.07c-.45 0-.82.31-.91.73l-.33 1.53c-.34-.96-1.16-1.53-2.31-1.53-2.39 0-4 1.94-4 4.8 0 3.2 1.81 4.96 4.22 4.96.96 0 1.77-.32 2.35-1l-.54 2.38c-.1.44.23.83.67.83h5.2c.45 0 .82-.31.91-.73l2.05-9.02c.03-.13.04-.26.04-.39V3.2zM38 10.13c-1.04 0-1.68-.61-1.68-1.59 0-1.08.76-1.68 1.82-1.68.99 0 1.59.55 1.59 1.57 0 1.05-.67 1.7-1.73 1.7zm11.72-7.88h-5.07c-.45 0-.82.31-.91.73l-.34 1.48c-.54-.91-1.39-1.48-2.6-1.48-2.39 0-4 1.94-4 4.8 0 3.21 1.81 4.96 4.22 4.96 1.34 0 2.22-.68 2.64-1.68l-.29 1.25c-.1.44.23.83.67.83h5.07c.45 0 .82-.31.91-.73l2.08-9.13c.03-.12.04-.26.04-.39v-1.68h-.01c-.01-.52-.44-.95-.96-.95zM46 10.13c-1.04 0-1.68-.61-1.68-1.59 0-1.08.76-1.68 1.82-1.68.99 0 1.59.55 1.59 1.57 0 1.05-.67 1.7-1.73 1.7zm11.73-7.88h-5.07c-.45 0-.82.31-.91.73L51 5.37c-.77-.92-1.79-1.32-3.13-1.32-.45 0-.82.31-.91.73l-1.62 7.15c-.1.44.23.83.67.83h5.07c.45 0 .82-.31.91-.73l1.83-8.03c.01-.06.02-.13.02-.2v-.68c-.01-.52-.44-.95-.96-.95zM53.3 12.08h5.07c.45 0 .82-.31.91-.73l.63-2.77c.34-.96 1.16-1.53 2.31-1.53 2.39 0 4 1.94 4 4.8 0 3.2 1.81 4.96 4.22 4.96.96 0 1.77-.32 2.35-1l-.54 2.38c-.1.44.23.83.67.83h5.2c.45 0 .82-.31.91-.73l2.05-9.02c.03-.13.04-.26.04-.39V3.2c0-.52-.43-.95-.95-.95h-5.07c-.45 0-.82.31-.91.73l-.33 1.53c-.34-.96-1.16-1.53-2.31-1.53-2.39 0-4 1.94-4 4.8 0 3.2 1.81 4.96 4.22 4.96.96 0 1.77-.32 2.35-1l-.54 2.38c-.1.44.23.83.67.83h5.2c.45 0 .82-.31.91-.73l2.05-9.02c.03-.13.04-.26.04-.39V3.2c0-.52-.43-.95-.95-.95h-5.07c-.45 0-.82.31-.91.73l-.33 1.53c-.34-.96-1.16-1.53-2.31-1.53-2.39 0-4 1.94-4 4.8 0 3.2 1.81 4.96 4.22 4.96.96 0 1.77-.32 2.35-1l-.54 2.38c-.1.44.23.83.67.83h5.2c.45 0 .82-.31.91-.73l2.05-9.02c.03-.13.04-.26.04-.39V3.2c0-.52-.43-.95-.95-.95h-5.07c-.45 0-.82.31-.91.73l-.33 1.53z"/></svg>
                        <span class="text-xs font-bold tracking-tighter uppercase whitespace-nowrap">Stripe Atlas</span>
                    </div>
                    <!-- Mercury -->
                    <div class="flex items-center space-x-2">
                        <svg class="h-6 w-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                        <span class="text-xs font-bold tracking-tighter uppercase whitespace-nowrap">Mercury Banking</span>
                    </div>
                    <!-- Companies House -->
                    <div class="flex items-center space-x-2">
                        <span class="text-xs font-black tracking-tighter whitespace-nowrap border-2 border-gray-900 px-2 py-0.5">COMPANIES HOUSE</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Video Introduction Section -->
    <section class="pb-24 bg-white relative overflow-hidden">
        <div class="container mx-auto px-4">
            <div class="max-w-5xl mx-auto">
                <div class="text-center mb-12">
                    <h2 class="text-3xl md:text-5xl font-black text-gray-900 mb-4 tracking-tight">Watch Our Official Guide</h2>
                    <p class="text-lg text-gray-700 font-medium">Learn how we simplify UK company registration for global founders in 2026.</p>
                </div>
                
                <div class="relative rounded-[2.5rem] overflow-hidden shadow-[0_32px_64px_-15px_rgba(0,0,0,0.2)] bg-gray-900 aspect-video">
                    <iframe 
                        class="absolute inset-0 w-full h-full"
                        src="https://www.youtube.com/embed/e6D8na1vAm8?si=SYOlzZmFMOVANO24" 
                        title="YouTube video player" 
                        frameborder="0" 
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                        referrerpolicy="strict-origin-when-cross-origin" 
                        allowfullscreen>
                    </iframe>
                </div>
            </div>
        </div>
    </section>

    <!-- Cohesive Launch Center -->
    <section id="tools" class="py-24 bg-white overflow-hidden">
        <div class="container mx-auto px-4 relative">
            <!-- Background Decorative Elements -->
            <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 bg-blue-50 rounded-full blur-3xl opacity-50"></div>
            <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-96 h-96 bg-indigo-50 rounded-full blur-3xl opacity-50"></div>

            <div class="max-w-5xl mx-auto relative z-10">
                <div class="text-center mb-16">
                    <h2 class="text-4xl font-extrabold text-gray-900 mb-4">Strategic Research Hub</h2>
                    <p class="text-xl text-gray-700">Everything you need to validate your brand and classify your vision.</p>
                </div>

                <div class="bg-white rounded-3xl shadow-2xl border border-gray-100 p-2 md:p-4 overflow-hidden">
                    <div class="flex flex-col lg:flex-row">
                        <!-- Step 1: Company Search -->
                        <div class="flex-1 p-8 md:p-12 border-b lg:border-b-0 lg:border-r border-gray-100">
                            <div class="flex items-center mb-6">
                                <span class="w-12 h-12 bg-blue-600 text-white rounded-2xl flex items-center justify-center font-black text-xl shadow-lg shadow-blue-200 mr-4">01</span>
                                <h3 class="text-2xl font-bold text-gray-900">Brand Availability</h3>
                            </div>
                            <p class="text-gray-700 mb-8">Search the official Companies House registry to secure your unique business name.</p>
                            
                            <div class="relative group">
                                <input type="text" id="company-q" placeholder="Enter desired name..." 
                                    class="w-full pl-6 pr-32 py-5 bg-gray-50 border-2 border-transparent focus:border-blue-600 focus:bg-white rounded-2xl transition-all duration-300 outline-none text-lg font-medium shadow-inner">
                                <button onclick="searchCompany()" 
                                    class="absolute right-2 top-2 bottom-2 bg-blue-600 text-white px-8 rounded-xl font-bold hover:bg-blue-700 transition shadow-lg shadow-blue-100 active:scale-95">
                                    Verify
                                </button>
                            </div>
                            <div id="company-results" class="mt-6 space-y-3 max-h-60 overflow-y-auto pr-2 custom-scrollbar"></div>
                        </div>

                        <!-- Step 2: SIC Finder -->
                        <div class="flex-1 p-8 md:p-12 bg-gray-50/50">
                            <div class="flex items-center mb-6">
                                <span class="w-12 h-12 bg-indigo-600 text-white rounded-2xl flex items-center justify-center font-black text-xl shadow-lg shadow-indigo-200 mr-4">02</span>
                                <h3 class="text-2xl font-bold text-gray-900">Activity Classification</h3>
                            </div>
                            <p class="text-gray-700 mb-8">Identify the correct SIC codes to define your company's official scope of operations.</p>
                            
                            <div class="relative group">
                                <input type="text" id="sic-q" placeholder="Search activities (e.g. tech, retail)..." 
                                    class="w-full pl-6 pr-32 py-5 bg-white border-2 border-transparent focus:border-indigo-600 rounded-2xl transition-all duration-300 outline-none text-lg font-medium shadow-sm">
                                <button onclick="searchSIC()" 
                                    class="absolute right-2 top-2 bottom-2 bg-indigo-600 text-white px-8 rounded-xl font-bold hover:bg-indigo-700 transition shadow-lg shadow-indigo-100 active:scale-95">
                                    Search
                                </button>
                            </div>
                            <div id="sic-results" class="mt-6 space-y-3 max-h-60 overflow-y-auto pr-2 custom-scrollbar"></div>
                        </div>
                    </div>
                </div>

                <!-- Strategic Tip -->
                <div class="mt-12 flex items-center justify-center text-gray-600 bg-white/50 backdrop-blur-sm py-4 px-8 rounded-full border border-gray-100 w-fit mx-auto">
                    <svg class="w-5 h-5 text-yellow-500 mr-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M11 3a1 1 0 10-2 0v1a1 1 0 102 0V3zM15.657 5.757a1 1 0 00-1.414-1.414l-.707.707a1 1 0 001.414 1.414l.707-.707zM18 10a1 1 0 01-1 1h-1a1 1 0 110-2h1a1 1 0 011 1zM5.05 6.464A1 1 0 106.464 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zM5 10a1 1 0 01-1 1H3a1 1 0 110-2h1a1 1 0 011 1zM8 16v-1a1 1 0 112 0v1a1 1 0 11-2 0zM13.464 15.657a1 1 0 010-1.414l.707-.707a1 1 0 111.414 1.414l-.707.707a1 1 0 01-1.414 0zM10 8a2 2 0 100 4 2 2 0 000-4z"></path></svg>
                    <span class="text-sm font-medium">Pro Tip: Use the most specific SIC code possible to ensure your company bank account application is approved faster.</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Packages Section -->
    <section class="py-24 bg-gray-50">
        <div class="container mx-auto px-4">
            <div class="text-center mb-16">
                <h2 class="text-4xl font-extrabold text-gray-900 mb-4">Formation Packages</h2>
                <p class="text-xl text-gray-700">Choose the perfect foundation for your business growth.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-7xl mx-auto">
                <% packages.forEach(pkg => { %>
                    <div class="relative bg-white p-8 rounded-3xl border <%= pkg.popular ? 'border-blue-600 shadow-2xl scale-105 z-10' : 'border-gray-200 hover:shadow-xl' %> transition-all duration-300 flex flex-col">
                        <% if (pkg.popular) { %>
                            <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 bg-blue-600 text-white px-6 py-1 rounded-full font-bold text-sm tracking-wide shadow-lg">
                                MOST POPULAR
                            </div>
                        <% } %>
                        
                        <div class="mb-8">
                            <h3 class="text-2xl font-bold text-gray-900 mb-2"><%= pkg.name %></h3>
                            <p class="text-gray-600 text-sm h-10"><%= pkg.description %></p>
                        </div>

                        <div class="flex items-baseline mb-8">
                            <span class="text-5xl font-black text-gray-900"><%= pkg.price %></span>
                            <span class="text-gray-500 ml-2 font-medium">+ VAT</span>
                        </div>

                        <ul class="space-y-4 mb-10 flex-1">
                            <% pkg.features.forEach((feature, idx) => { %>
                                <li class="flex items-start">
                                    <div class="mt-1 flex-shrink-0 w-5 h-5 bg-green-100 rounded-full flex items-center justify-center">
                                        <svg class="w-3.5 h-3.5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                    </div>
                                    <span class="ml-3 text-gray-700 <%= (pkg.popular && idx < 3) ? 'font-semibold' : '' %>"><%= feature %></span>
                                </li>
                            <% }) %>
                        </ul>

                        <a href="/checkout?package=<%= pkg.name.toLowerCase() %>" class="block text-center py-4 rounded-xl font-extrabold text-lg transition-all duration-300 <%= pkg.popular ? 'bg-blue-600 text-white hover:bg-blue-700 shadow-blue-200 shadow-lg' : 'border-2 border-blue-600 text-blue-600 hover:bg-blue-50' %>">
                            <%= pkg.cta %>
                        </a>
                    </div>
                <% }) %>
            </div>
        </div>
    </section>
    <!-- Testimonials Section -->
    <section class="py-24 bg-white overflow-hidden">
        <div class="container mx-auto px-4">
            <div class="text-center mb-16">
                <h2 class="text-4xl font-extrabold text-gray-900 mb-4">Success Stories</h2>
                <p class="text-xl text-gray-700">Join thousands of founders who launched with UK Ltd Registration.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Testimonial 1 -->
                <div class="glass p-8 rounded-3xl relative">
                    <div class="flex items-center mb-6">
                        <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mr-4">
                            <span class="text-blue-600 font-bold">AS</span>
                        </div>
                        <div>
                            <h3 class="font-bold text-gray-900">Ahmed S.</h3>
                            <p class="text-xs text-gray-600">Tech Founder, UAE</p>
                        </div>
                    </div>
                    <p class="text-gray-700 italic leading-relaxed">"The transition to the 2026 regulations was seamless. I had my company registered and Wise account ready in under 48 hours."</p>
                    <div class="mt-6 flex text-yellow-400">
                        <% for(let i=0; i<5; i++) { %>
                            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                        <% } %>
                    </div>
                </div>

                <!-- Testimonial 2 -->
                <div class="glass p-8 rounded-3xl relative bg-blue-50/30">
                    <div class="flex items-center mb-6">
                        <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mr-4">
                            <span class="text-green-600 font-bold">ML</span>
                        </div>
                        <div>
                            <h3 class="font-bold text-gray-900">Maria L.</h3>
                            <p class="text-xs text-gray-600">E-commerce, Brazil</p>
                        </div>
                    </div>
                    <p class="text-gray-700 italic leading-relaxed">"Being a non-resident, I was worried about the banking part. The team helped me get my SIC codes right for high approval rates."</p>
                    <div class="mt-6 flex text-yellow-400">
                        <% for(let i=0; i<5; i++) { %>
                            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                        <% } %>
                    </div>
                </div>

                <!-- Testimonial 3 -->
                <div class="glass p-8 rounded-3xl relative">
                    <div class="flex items-center mb-6">
                        <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center mr-4">
                            <span class="text-purple-600 font-bold">JK</span>
                        </div>
                        <div>
                            <h3 class="font-bold text-gray-900">John K.</h3>
                            <p class="text-xs text-gray-600">Consultant, UK</p>
                        </div>
                    </div>
                    <p class="text-gray-700 italic leading-relaxed">"Professional, fast, and transparent. The only formation service I've found that actually explains the 2026 changes clearly."</p>
                    <div class="mt-6 flex text-yellow-400">
                        <% for(let i=0; i<5; i++) { %>
                            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Snippet Section -->
    <section class="py-24 bg-gray-50">
        <div class="container mx-auto px-4">
            <div class="max-w-4xl mx-auto">
                <div class="text-center mb-16">
                    <h2 class="text-4xl font-extrabold text-gray-900 mb-4">Common Questions</h2>
                    <p class="text-xl text-gray-700">Quick answers to help you launch with confidence.</p>
                </div>


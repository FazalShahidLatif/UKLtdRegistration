<%- include('../partials/header') %>
<%- include('../partials/navigation') %>

<main class="min-h-screen pt-12 pb-24">
    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-4 mb-20 text-center">
        <div class="inline-block px-4 py-1.5 mb-6 bg-brand-blue/10 text-brand-blue rounded-full text-xs font-black tracking-widest uppercase">
            Knowledge Hub
        </div>
        <h1 class="text-5xl md:text-6xl font-black text-gray-900 mb-6 tracking-tighter">
            Strategic Insights for <span class="text-brand-blue">Global Founders.</span>
        </h1>
    </section>
    
    <!-- Industry Opportunity Spotlight -->
    <section class="max-w-7xl mx-auto px-4 mb-24">
        <div class="bg-slate-900 rounded-[3rem] p-8 md:p-16 relative overflow-hidden shadow-2xl shadow-slate-200">
            <!-- Decoration -->
            <div class="absolute top-0 right-0 w-64 h-64 bg-brand-blue/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
            
            <div class="relative z-10">
                <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
                    <div class="max-w-2xl">
                        <span class="inline-block px-3 py-1 bg-brand-blue/20 text-brand-blue rounded-lg text-[10px] font-black uppercase tracking-widest mb-4">Strategic Global Opportunities</span>
                        <h2 class="text-3xl md:text-4xl font-black text-white mb-6 tracking-tighter">High-Profit Niches <span class="text-brand-blue">Hidden in Plain Sight.</span></h2>
                        <p class="text-slate-400 font-medium leading-relaxed text-sm md:text-base">Most founders stick to standard e-commerce. We help you unlock complex, high-ticket industries that leverage the full power of a UK Limited Company to win global tenders and dominate local markets.</p>
                    </div>
                    <a href="/strategic-research-hub" class="bg-white text-slate-900 px-8 py-4 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-brand-blue hover:text-white transition-all shadow-xl shadow-slate-950/20">Explore All Niches</a>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
                    <!-- Niche 1 -->
                    <div class="bg-white/5 border border-white/10 p-6 rounded-3xl hover:bg-white/10 transition-all group">
                        <div class="w-12 h-12 bg-indigo-500/20 text-indigo-400 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.673.337a4 4 0 01-2.574.344l-3.347-.669a2 2 0 01-1.242-2.534l.34-1.018a2 2 0 012.534-1.242l.317.106a2 2 0 001.282 0l2.356-.785a2 2 0 001.283 0l2.356.785a2 2 0 001.283 0l2.356-.785a2 2 0 001.283 0l2.356-.785a2 2 0 001.283 0l1.93.643a2 2 0 011.242 2.532l-.497 1.492a2 2 0 01-2.532 1.242l-.643-.214z"></path></svg>
                        </div>
                        <h4 class="text-white font-black text-[10px] uppercase tracking-widest mb-2">Lubricants & Gases</h4>
                        <p class="text-slate-400 text-[9px] font-bold leading-relaxed mb-4">High-ticket energy and industrial tenders.</p>
                        <span class="inline-block px-2 py-0.5 bg-green-500/20 text-green-400 rounded-md text-[8px] font-black tracking-widest uppercase">High Profit</span>
                    </div>

                    <!-- Niche 2 -->
                    <div class="bg-white/5 border border-white/10 p-6 rounded-3xl hover:bg-white/10 transition-all group">
                        <div class="w-12 h-12 bg-blue-500/20 text-blue-400 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        </div>
                        <h4 class="text-white font-black text-[10px] uppercase tracking-widest mb-2">GPS & GPRS Tech</h4>
                        <p class="text-slate-400 text-[9px] font-bold leading-relaxed mb-4">Military and government tracking systems.</p>
                        <span class="inline-block px-2 py-0.5 bg-brand-blue/20 text-brand-blue rounded-md text-[8px] font-black tracking-widest uppercase">High Spec</span>
                    </div>

                    <!-- Niche 3 -->
                    <div class="bg-white/5 border border-white/10 p-6 rounded-3xl hover:bg-white/10 transition-all group">
                        <div class="w-12 h-12 bg-amber-500/20 text-amber-400 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                        </div>
                        <h4 class="text-white font-black text-[10px] uppercase tracking-widest mb-2">Refurbished Machinery</h4>
                        <p class="text-slate-400 text-[9px] font-bold leading-relaxed mb-4">Heavy equipment for global infrastructure.</p>
                        <span class="inline-block px-2 py-0.5 bg-amber-500/20 text-amber-400 rounded-md text-[8px] font-black tracking-widest uppercase">Scalable</span>
                    </div>

                    <!-- Niche 4 -->
                    <div class="bg-white/5 border border-white/10 p-6 rounded-3xl hover:bg-white/10 transition-all group">
                        <div class="w-12 h-12 bg-red-500/20 text-red-400 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"></path></svg>
                        </div>
                        <h4 class="text-white font-black text-[10px] uppercase tracking-widest mb-2">Salvage Cars</h4>
                        <p class="text-slate-400 text-[9px] font-bold leading-relaxed mb-4">The Dubai corridor for salvage export.</p>
                        <span class="inline-block px-2 py-0.5 bg-red-500/20 text-red-400 rounded-md text-[8px] font-black tracking-widest uppercase">High Yield</span>
                    </div>

                    <!-- Niche 5 -->
                    <div class="bg-white/5 border border-white/10 p-6 rounded-3xl hover:bg-white/10 transition-all group">
                        <div class="w-12 h-12 bg-emerald-500/20 text-emerald-400 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
                        </div>
                        <h4 class="text-white font-black text-[10px] uppercase tracking-widest mb-2">Coffee & Food</h4>
                        <p class="text-slate-400 text-[9px] font-bold leading-relaxed mb-4">Scaling premium agri-trade globally.</p>
                        <span class="inline-block px-2 py-0.5 bg-emerald-500/20 text-emerald-400 rounded-md text-[8px] font-black tracking-widest uppercase">Recurrent</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Article Search/Filter -->
    <section class="max-w-7xl mx-auto px-4 mb-12">
        <div class="glass p-4 rounded-3xl flex flex-col md:flex-row gap-4 items-center justify-between">
            <div class="flex flex-wrap gap-2" id="filter-buttons">
                <button onclick="filterCategory('All')" class="filter-btn px-6 py-2 bg-brand-blue text-white rounded-xl font-bold text-sm" data-category="All">All Articles</button>
                <button onclick="filterCategory('Compliance')" class="filter-btn px-6 py-2 bg-white text-gray-500 hover:text-brand-blue rounded-xl font-bold text-sm transition-colors" data-category="Compliance">Compliance</button>
                <button onclick="filterCategory('Tax & Finance')" class="filter-btn px-6 py-2 bg-white text-gray-500 hover:text-brand-blue rounded-xl font-bold text-sm transition-colors" data-category="Tax & Finance">Tax & Finance</button>
                <button onclick="filterCategory('Address Services')" class="filter-btn px-6 py-2 bg-white text-gray-500 hover:text-brand-blue rounded-xl font-bold text-sm transition-colors" data-category="Address Services">Address Services</button>
                <button onclick="filterCategory('Banking')" class="filter-btn px-6 py-2 bg-white text-gray-500 hover:text-brand-blue rounded-xl font-bold text-sm transition-colors" data-category="Banking">Banking</button>
            </div>
            <div class="relative w-full md:w-96">
                <input type="text" id="searchInput" onkeyup="searchArticles()" placeholder="Search insights..." class="w-full pl-12 pr-4 py-3 bg-gray-50 border-none rounded-2xl text-sm font-medium focus:ring-2 focus:ring-brand-blue transition-all">
                <svg class="w-5 h-5 text-gray-400 absolute left-4 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </div>
        </div>
    </section>

    <!-- Article Grid -->
    <section class="max-w-7xl mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="article-grid">
            <% articles.forEach(article => { %>
                <a href="/knowledge-hub/<%= article.id %>" data-category="<%= article.category %>" class="article-card group bg-white rounded-[2.5rem] border border-gray-100 p-8 shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 flex flex-col">
                    <div class="mb-6 flex justify-between items-start">
                        <span class="px-3 py-1 bg-gray-50 text-gray-500 rounded-lg text-[10px] font-black uppercase tracking-widest"><%= article.category %></span>
                        <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest"><%= article.readTime %></span>
                    </div>
                    <h3 class="text-2xl font-black text-gray-900 mb-4 group-hover:text-brand-blue transition-colors line-clamp-2">
                        <%= article.title %>
                    </h3>
                    <p class="text-gray-700 text-sm font-medium mb-8 flex-1 line-clamp-3">
                        <%= article.summary %>
                    </p>
                    <div class="flex items-center text-brand-blue font-black text-xs uppercase tracking-widest">
                        Read Full Guide
                        <svg class="w-4 h-4 ml-2 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                    </div>
                </a>
            <% }); %>
        </div>

        <!-- Empty state -->
        <div id="no-results" class="hidden text-center py-20">
            <p class="text-gray-400 font-bold text-lg mb-4">No articles match your search.</p>
            <button onclick="filterCategory('All'); document.getElementById('searchInput').value=''" class="text-brand-blue font-black text-sm uppercase tracking-widest hover:underline">Clear Filters</button>
        </div>
    </section>
</main>

<script>
    let currentCategory = 'All';

    function filterCategory(category) {
        currentCategory = category;
        
        document.querySelectorAll('.filter-btn').forEach(btn => {
            if (btn.dataset.category === category) {
                btn.className = 'filter-btn px-6 py-2 bg-brand-blue text-white rounded-xl font-bold text-sm';
            } else {
                btn.className = 'filter-btn px-6 py-2 bg-white text-gray-500 hover:text-brand-blue rounded-xl font-bold text-sm transition-colors';
            }
        });

        searchArticles();
    }

    function searchArticles() {
        const query = document.getElementById('searchInput').value.toLowerCase();
        const cards = document.querySelectorAll('.article-card');
        let visible = 0;

        cards.forEach(card => {
            const title = card.querySelector('h3').innerText.toLowerCase();
            const summary = card.querySelector('p').innerText.toLowerCase();
            const categoryMatch = currentCategory === 'All' || card.dataset.category === currentCategory;
            const searchMatch = title.includes(query) || summary.includes(query);

            if (categoryMatch && searchMatch) {
                card.style.display = 'flex';
                visible++;
            } else {
                card.style.display = 'none';
            }
        });

        document.getElementById('no-results').classList.toggle('hidden', visible > 0);
    }
</script>

<%- include('../partials/footer') %>

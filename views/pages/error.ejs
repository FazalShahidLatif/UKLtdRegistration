<%- include('../partials/header') %>
<%- include('../partials/navigation') %>

<main class="container mx-auto px-4 py-20 text-center">
    <div class="max-w-xl mx-auto">
        <div class="bg-red-50 p-8 rounded-2xl border border-red-100">
            <h1 class="text-3xl font-bold text-red-700 mb-4">Something went wrong</h1>
            <p class="text-gray-700 mb-6">We encountered an error while processing your request. Our team has been notified.</p>
            <% if (error && error.stack) { %>
                <pre class="bg-gray-900 text-green-400 p-4 rounded-lg text-left overflow-auto text-xs max-h-60 mt-6"><%= error.stack %></pre>
            <% } %>
            <a href="/" class="bg-blue-600 text-white px-8 py-3 rounded-lg font-bold hover:bg-blue-700 transition mt-10 inline-block">Back to Safety</a>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>

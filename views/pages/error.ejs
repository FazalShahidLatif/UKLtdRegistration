<%- include('../partials/header') %>
<%- include('../partials/navigation') %>

<main class="relative min-h-[80vh] flex items-center justify-center overflow-hidden bg-slate-50">
    <!-- Background Decor -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
        <div class="absolute -top-24 -left-24 w-96 h-96 bg-red-500/5 rounded-full blur-3xl animate-pulse"></div>
        <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-brand-blue/5 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-3xl mx-auto text-center">
            <!-- Error Icon -->
            <div class="mb-8 inline-flex items-center justify-center w-24 h-24 rounded-3xl bg-red-100 text-red-600 shadow-inner">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
            </div>

            <div class="glass p-8 md:p-12 rounded-[2.5rem] relative">
                <h1 class="text-3xl md:text-5xl font-black text-brand-navy mb-6">Something Went Wrong</h1>
                <p class="text-lg text-gray-600 mb-8 max-w-lg mx-auto">
                    We've encountered an unexpected technical issue. Our systems have logged the incident, and our technical team has been notified.
                </p>

                <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                    <a href="/" class="btn-primary w-full sm:w-auto">
                        Back to Safety
                    </a>
                    <a href="/contact" class="px-8 py-4 rounded-2xl font-bold text-brand-navy border-2 border-brand-navy/10 hover:bg-brand-navy/5 transition-all duration-300 w-full sm:w-auto">
                        Report Issue
                    </a>
                </div>

                <% if (error && error.stack && process.env.NODE_ENV === 'development') { %>
                    <div class="mt-12 text-left">
                        <p class="text-xs font-bold text-red-400 uppercase tracking-widest mb-4">Developer Debug Context</p>
                        <div class="bg-gray-900 rounded-2xl p-6 overflow-x-auto border border-white/10 shadow-2xl">
                            <pre class="text-green-400 text-sm font-mono leading-relaxed"><%= error.stack %></pre>
                        </div>
                    </div>
                <% } %>
            </div>

            <div class="mt-8 text-sm text-gray-400">
                <p>Error Code: <%= error.status || 500 %> | Reference ID: <%= Math.random().toString(36).substr(2, 9).toUpperCase() %></p>
            </div>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
